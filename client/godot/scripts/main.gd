		str(zone_found),
		str(target_in_zone),
		str(arrived_zone),
		str(no_prompt),
		str(movement_stopped),
		str(battle_started),
		str(closed),
		encounter_grace_remaining,
		str(zone.get("id", "")),
		str(player_cell),
	])
	get_tree().quit(0 if status == "ok" else 1)


