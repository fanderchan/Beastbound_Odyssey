		status,
		str(contact_ok),
		target_distance,
		str(front_spacing_ok),
		_battle_front_row_min_spacing(BattleModel.SIDE_ALLY),
		_battle_front_row_min_spacing(BattleModel.SIDE_ENEMY),
	])
	get_tree().quit(0 if status == "ok" else 1)


