		and detail_text.find("骨刃") >= 0
		and detail_text.find("需求未满足") >= 0
		and detail_text.find("暂不生效") >= 0
		and detail_text.find("需求: Lv3") >= 0
		and slot_button != null
		and slot_button.has_theme_color_override("font_color")
