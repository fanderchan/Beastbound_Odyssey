		str(overlap_is_default),
		str(overlap_walkable),
		str(player_on_overlap),
		str(block_unwalkable),
		str(player_not_on_block),
		str(player_next_to_block),
		str(overlap_cell),
		str(block_cell),
		str(player_cell_after_block),
	])
