		host.get_tree().quit(1)
		return

	host.battle_state = BattleModel.set_actor_status(host.battle_state, "enemy_front_3", BattleModel.STATUS_POISON, 3, 7, BattleModel.PLAYER_ACTOR_ID)
	var poison_events = BattleModel.build_round_end_status_events(host.battle_state)
	var poison_event = {}
	for value in poison_events:
		var candidate = value as Dictionary
		if str(candidate.get("targetId", "")) == "enemy_front_3":
			poison_event = candidate
			break
	var poison_before_hp = int(BattleModel.actor_by_id(host.battle_state, "enemy_front_3").get("hp", 0))
	var poison_before_snapshots = host._battle_actor_snapshots_by_id()
	host.battle_state = BattleModel.apply_battle_event(host.battle_state, poison_event)
	var poison_ledger = BattleEventLedger.build_from_applied_state(host.battle_state, poison_event, poison_before_snapshots, host._battle_event_timeline_for_applied_event(poison_event))
	var poison_after = BattleModel.actor_by_id(host.battle_state, "enemy_front_3")
	var poison_ok = (
		str(poison_ledger.get("type", "")) == "status_tick"
		and str(poison_ledger.get("statusId", "")) == BattleModel.STATUS_POISON
		and int(poison_after.get("hp", 0)) == poison_before_hp - 7
		and BattleStatusModel.status_turns(poison_after, BattleModel.STATUS_POISON) == 2
	)

	host.battle_state = BattleModel.set_actor_status(host.battle_state, "enemy_back_1", BattleModel.STATUS_SLEEP, 2, 0, BattleModel.PLAYER_ACTOR_ID)
	var sleep_before_hp = int(BattleModel.actor_by_id(host.battle_state, BattleModel.PLAYER_ACTOR_ID).get("hp", 0))
	var sleep_event = {
		"type": "attack",
		"attackerId": "enemy_back_1",
		"targetId": BattleModel.PLAYER_ACTOR_ID,
		"targetSide": BattleModel.SIDE_ALLY,
		"damage": 20,
		"speed": 80,
			"sequence": 1,
			"movementStyle": "melee",
			"canLaunch": true,
			"forceDodge": false,
			"forceCritical": false,
		}
	var sleep_before_snapshots = host._battle_actor_snapshots_by_id()
	host.battle_state = BattleModel.apply_battle_event(host.battle_state, sleep_event)
	var sleep_ledger = BattleEventLedger.build_from_applied_state(host.battle_state, sleep_event, sleep_before_snapshots, host._battle_event_timeline_for_applied_event(sleep_event))
	var sleep_after_actor = BattleModel.actor_by_id(host.battle_state, "enemy_back_1")
	var sleep_ok = (
		str(sleep_ledger.get("type", "")) == "status_skip"
		and str(sleep_ledger.get("statusId", "")) == BattleModel.STATUS_SLEEP
		and int(BattleModel.actor_by_id(host.battle_state, BattleModel.PLAYER_ACTOR_ID).get("hp", 0)) == sleep_before_hp
		and BattleStatusModel.status_turns(sleep_after_actor, BattleModel.STATUS_SLEEP) == 1
	)

	var plain_damage = BattleModel.attack_damage_preview_for(host.battle_state, "ally_attack_high", "enemy_back_4")
	host.battle_state = BattleModel.set_actor_status(host.battle_state, "enemy_back_4", BattleModel.STATUS_STONE, 2, 0, BattleModel.PLAYER_ACTOR_ID)
	var stone_damage = BattleModel.attack_damage_preview_for(host.battle_state, "ally_attack_high", "enemy_back_4")
	var stone_ok = stone_damage < plain_damage

	host.battle_state = BattleModel.set_actor_status(host.battle_state, "ally_speed_fast", BattleModel.STATUS_CONFUSION, 2, 0, "enemy_back_2")
	var confusion_event = {
		"type": "attack",
		"attackerId": "ally_speed_fast",
		"targetId": "enemy_front_1",
		"targetSide": BattleModel.SIDE_ENEMY,
		"damage": 18,
		"speed": 120,
			"sequence": 2,
			"movementStyle": "melee",
			"canLaunch": false,
			"forceDodge": false,
			"forceCritical": false,
		}
	var confusion_before_snapshots = host._battle_actor_snapshots_by_id()
	host.battle_state = BattleModel.apply_battle_event(host.battle_state, confusion_event)
	var confusion_ledger = BattleEventLedger.build_from_applied_state(host.battle_state, confusion_event, confusion_before_snapshots, host._battle_event_timeline_for_applied_event(confusion_event))
	var confused_target = BattleModel.actor_by_id(host.battle_state, str(confusion_ledger.get("resolvedTargetId", "")))
	var confusion_ok = (
		str(confusion_ledger.get("statusResult", "")) == "confused_retarget"
		and bool(confusion_ledger.get("retargeted", false))
		and str(confused_target.get("side", "")) == BattleModel.SIDE_ALLY
		and BattleStatusModel.status_turns(BattleModel.actor_by_id(host.battle_state, "ally_speed_fast"), BattleModel.STATUS_CONFUSION) == 1
	)

	host.battle_state = BattleModel.set_actor_status(host.battle_state, "enemy_front_2", BattleModel.STATUS_SLEEP, 2, 0, BattleModel.PLAYER_ACTOR_ID)
	var wake_event = {
		"type": "attack",
		"attackerId": BattleModel.PLAYER_ACTOR_ID,
		"targetId": "enemy_front_2",
		"targetSide": BattleModel.SIDE_ENEMY,
		"damage": 1,
		"speed": 100,
			"sequence": 3,
			"movementStyle": "melee",
			"canLaunch": false,
			"forceDodge": false,
			"forceCritical": false,
		}
	host.battle_state = BattleModel.apply_battle_event(host.battle_state, wake_event)
	var wake_target = BattleModel.actor_by_id(host.battle_state, "enemy_front_2")
	var wake_ok = not BattleStatusModel.has_status(wake_target, BattleModel.STATUS_SLEEP)

	var status = "ok" if poison_ok and sleep_ok and stone_ok and confusion_ok and wake_ok else "failed"
	print("battle status check ready: status=%s poison=%s sleep=%s stone=%s confusion=%s wake=%s poison_hp=%d poison_turns=%d plain=%d stone=%d confused_target=%s" % [
		status,
		str(poison_ok),
		str(sleep_ok),
		str(stone_ok),
		str(confusion_ok),
		str(wake_ok),
		int(poison_after.get("hp", 0)),
		BattleStatusModel.status_turns(poison_after, BattleModel.STATUS_POISON),
		plain_damage,
		stone_damage,
		str(confusion_ledger.get("resolvedTargetId", "")),
	])
	host.get_tree().quit(0 if status == "ok" else 1)

func _run_auto_battle_status_skill_check() -> void:
	var started = host._start_stat_formula_test_battle()
