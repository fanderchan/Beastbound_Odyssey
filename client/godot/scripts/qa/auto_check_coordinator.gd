func _run_auto_npc_quest_marker_check() -> void:
	host.profile_save_enabled = false
	host.world_log_history.clear()
	host.world_log_message = ""

	host.player_profile = PlayerProgressModel.with_rebirth_count(PlayerProgressModel.default_profile(), 4)
	var loaded_village = host._load_map("firebud_village_gate", "from_training_yard")
	var stable_keeper = InteractionModel.find_by_id(host.map_data, "firebud_stable_keeper")
	var available_ok = loaded_village and host._quest_marker_state_for_item(stable_keeper) == QUEST_MARKER_AVAILABLE

	host.player_profile = host._profile_with_active_quest("quest_intro_talk")
	var loaded_training = host._load_map("firebud_training_yard")
	var trainer = InteractionModel.find_by_id(host.map_data, "trainer")
	var accepted_talk_ok = loaded_training and host._quest_marker_state_for_item(trainer) == QUEST_MARKER_IN_PROGRESS

	host.player_profile = host._profile_with_active_quest("quest_buy_supply")
	loaded_village = host._load_map("firebud_village_gate", "from_training_yard")
	var shopkeeper = InteractionModel.find_by_id(host.map_data, "firebud_shopkeeper")
	var in_progress_ok = loaded_village and host._quest_marker_state_for_item(shopkeeper) == QUEST_MARKER_IN_PROGRESS

	var ready_profile = host._profile_with_active_quest("quest_buy_supply")
	var buy_event = PlayerProgressModel.record_quest_event(ready_profile, {
		"type": "buy_item",
		"shopId": "firebud_item_shop",
		"itemId": "item_meat_small",
		"amount": 1,
	})
	host.player_profile = buy_event.get("profile", ready_profile) as Dictionary
	var ready_ok = host._quest_marker_state_for_item(shopkeeper) == QUEST_MARKER_READY

	host.player_profile = PlayerProgressModel.with_rebirth_count(PlayerProgressModel.default_profile(), 3)
	var blocked_ok = (
		loaded_village
		and host._quest_marker_state_for_item(stable_keeper) == QUEST_MARKER_BLOCKED
	)

	host.player_profile = PlayerProgressModel.with_unlocked_ability(host._profile_after_six_rebirths_for_test(), PlayerProgressModel.ABILITY_REMOTE_STABLE)
	var completed_hidden_ok = (
		PlayerProgressModel.active_quest_id(host.player_profile) == ""
		and host._quest_marker_state_for_item(stable_keeper) == QUEST_MARKER_NONE
	)
	var completed_signature = host._quest_marker_signature()

	var mentor = InteractionModel.find_by_id(host.map_data, "firebud_rebirth_mentor")
	var rebirth_blocked_profile = PlayerProgressModel.default_profile()
	rebirth_blocked_profile[PlayerProgressModel.ACTIVE_QUEST_ID_KEY] = ""
	host.player_profile = rebirth_blocked_profile
	var rebirth_blocked_marker_ok = host._quest_marker_state_for_item(mentor) == QUEST_MARKER_BLOCKED
	var rebirth_available_profile = host._profile_with_rebirth_test_level(rebirth_blocked_profile, RebirthModel.MIN_REBIRTH_LEVEL)
	rebirth_available_profile[PlayerProgressModel.ACTIVE_QUEST_ID_KEY] = ""
	host.player_profile = rebirth_available_profile
	var rebirth_available_marker_ok = host._quest_marker_state_for_item(mentor) == QUEST_MARKER_REBIRTH_AVAILABLE
	var rebirth_progress_profile = PlayerProgressModel.with_rebirth_quest_completed(rebirth_available_profile, 1, true)
	host.player_profile = rebirth_progress_profile
	var rebirth_progress_marker_ok = host._quest_marker_state_for_item(mentor) == QUEST_MARKER_IN_PROGRESS
	var rebirth_ready_profile = host._profile_with_rebirth_trial_resources_for_test(rebirth_progress_profile, 1)
	host.player_profile = rebirth_ready_profile
	var rebirth_ready_marker_ok = host._quest_marker_state_for_item(mentor) == QUEST_MARKER_REBIRTH_READY
	var rebirth_execute_result = PlayerProgressModel.execute_rebirth(rebirth_ready_profile)
	host.player_profile = rebirth_execute_result.get("profile", rebirth_ready_profile) as Dictionary
	var rebirth_after_marker_ok = host._quest_marker_state_for_item(mentor) == QUEST_MARKER_BLOCKED
	var rebirth_marker_ok = (
		rebirth_blocked_marker_ok
		and rebirth_available_marker_ok
		and rebirth_progress_marker_ok
		and rebirth_ready_marker_ok
		and rebirth_after_marker_ok
	)
	var signature_ok = completed_signature.find("abilities:remoteStable") >= 0
	var visual_ok = (
		str(host._quest_marker_visual_for_state(QUEST_MARKER_AVAILABLE).get("glyph", "")) == "!"
		and str(host._quest_marker_visual_for_state(QUEST_MARKER_AVAILABLE).get("tone", "")) == "yellow"
		and str(host._quest_marker_visual_for_state(QUEST_MARKER_BLOCKED).get("glyph", "")) == "!"
		and str(host._quest_marker_visual_for_state(QUEST_MARKER_BLOCKED).get("tone", "")) == "red"
		and str(host._quest_marker_visual_for_state(QUEST_MARKER_IN_PROGRESS).get("glyph", "")) == "?"
		and str(host._quest_marker_visual_for_state(QUEST_MARKER_IN_PROGRESS).get("tone", "")) == "gray"
		and str(host._quest_marker_visual_for_state(QUEST_MARKER_READY).get("glyph", "")) == "?"
		and str(host._quest_marker_visual_for_state(QUEST_MARKER_READY).get("tone", "")) == "yellow"
		and str(host._quest_marker_visual_for_state(QUEST_MARKER_REBIRTH_AVAILABLE).get("glyph", "")) == "!"
		and str(host._quest_marker_visual_for_state(QUEST_MARKER_REBIRTH_AVAILABLE).get("tone", "")) == "gray"
		and str(host._quest_marker_visual_for_state(QUEST_MARKER_REBIRTH_READY).get("glyph", "")) == "!"
		and str(host._quest_marker_visual_for_state(QUEST_MARKER_REBIRTH_READY).get("tone", "")) == "yellow"
	)

	var status = "ok" if available_ok and accepted_talk_ok and in_progress_ok and ready_ok and blocked_ok and completed_hidden_ok and rebirth_marker_ok and signature_ok and visual_ok else "failed"
	print("npc quest marker check ready: status=%s available=%s accepted_talk=%s in_progress=%s ready=%s blocked=%s hidden=%s rebirth=%s rebirth_steps=%s/%s/%s/%s/%s visual=%s signature=%s active=%s" % [
		status,
		str(available_ok),
		str(accepted_talk_ok),
		str(in_progress_ok),
		str(ready_ok),
		str(blocked_ok),
		str(completed_hidden_ok),
		str(rebirth_marker_ok),
		str(rebirth_blocked_marker_ok),
		str(rebirth_available_marker_ok),
		str(rebirth_progress_marker_ok),
		str(rebirth_ready_marker_ok),
		str(rebirth_after_marker_ok),
		str(visual_ok),
		completed_signature,
		PlayerProgressModel.active_quest_id(host.player_profile),
	])
	host.get_tree().quit(0 if status == "ok" else 1)

