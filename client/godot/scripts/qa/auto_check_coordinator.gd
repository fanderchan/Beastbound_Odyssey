	var outsider_team_messages: Array = outsider_team_parsed.get("messages", []) if outsider_team_parsed.get("messages", []) is Array else []
	var team_ok = bool(team_send_parsed.get("ok", false)) and host._chat_message_list_contains(leader_team_messages, team_text) and not host._chat_message_list_contains(outsider_team_messages, team_text)

