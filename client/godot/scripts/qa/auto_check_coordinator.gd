func _qa_send_touch_press(screen_point: Vector2) -> void:
	var event := InputEventScreenTouch.new()
	event.index = 0
	event.pressed = true
	event.position = screen_point
	host._input(event)


func _qa_control_inside_viewport(control: Control, viewport_rect: Rect2) -> bool:
	if control == null or not control.visible:
		return false
	var rect := control.get_global_rect()
	var expanded := viewport_rect.grow(1.0)
	return (
		rect.size.x > 0.0
		and rect.size.y > 0.0
		and rect.position.x >= expanded.position.x
		and rect.position.y >= expanded.position.y
		and rect.end.x <= expanded.end.x
		and rect.end.y <= expanded.end.y
	)


func _qa_control_rect_text(control: Control) -> String:
	if control == null:
		return "null"
	return "visible=%s rect=%s min=%s" % [
		str(control.visible),
		str(control.get_global_rect()),
		str(control.get_combined_minimum_size()),
	]


func _qa_battle_touch_point_for_target(target_id: String, center: Vector2, viewport_rect: Rect2) -> Vector2:
	var offsets: Array[Vector2] = [
		Vector2.ZERO,
		Vector2(0, -18),
		Vector2(-12, -18),
		Vector2(12, -18),
		Vector2(-24, -18),
		Vector2(24, -18),
		Vector2(0, -32),
		Vector2(-12, -32),
		Vector2(12, -32),
		Vector2(-24, -32),
		Vector2(24, -32),
		Vector2(0, 12),
		Vector2(-12, 12),
		Vector2(12, 12),
	]
	for offset in offsets:
		var candidate := center + offset
		if not viewport_rect.grow(-6.0).has_point(candidate):
			continue
		if host._battle_point_overlaps_panel(candidate):
			continue
		if host._battle_actor_id_at_screen_point(candidate, BattleModel.SIDE_ENEMY) == target_id:
			return candidate
	return center


func _set_host_battle_event_queue(events: Array) -> void:
	var typed_events: Array[Dictionary] = []
	for event in events:
		if event is Dictionary:
			typed_events.append(event as Dictionary)
	host.battle_event_queue = typed_events


func _run_auto_movement_check() -> void:
	var start_position = host.player.global_position
	var target = IsoMapModel.grid_to_world(host.map_data, IsoMapModel.spawn_cell(host.map_data) + Vector2i(2, -2))
	host._set_click_move_target(host._world_to_screen(target))
	for _step in range(18):
		await host.get_tree().physics_frame
	var end_position = host.player.global_position
	var moved_right = end_position.x > start_position.x
	var status = "ok" if moved_right else "failed"
	print("click movement check ready: status=%s start_x=%.2f end_x=%.2f target_x=%.2f path_len=%d click_input=true" % [
		status,
		start_position.x,
		end_position.x,
		target.x,
		host.current_path_cells.size(),
	])
	host.get_tree().quit(0 if moved_right else 1)

func _run_auto_party_member_follow_check() -> void:
	host.profile_save_enabled = false
	host.world_log_message = ""
	var loaded = host._load_map("firebud_village_gate", "from_training_yard")
	var saved_session = host.current_account_session.duplicate(true)
	var saved_party_state = host.party_current_state.duplicate(true)
	host.current_account_session = {
		"accountId": "member_account",
		"username": "member",
		"displayName": "队员",
		"authSource": ServerAuthClientModel.SOURCE_SERVER,
		"serverSessionToken": "token_test",
		"serverBaseUrl": ServerAuthClientModel.DEFAULT_BASE_URL,
	}
	host.party_current_state = {
		"party": {
			"leaderAccountId": "leader_account",
			"members": [
				{"accountId": "leader_account", "username": "leader", "role": "leader"},
				{"accountId": "member_account", "username": "member", "role": "member"},
			],
		},
		"incomingInvites": [],
		"maxMembers": 5,
	}
	var start_cell = Vector2i.ZERO
	var follow_cell = Vector2i.ZERO
	var click_block_cell = Vector2i.ZERO
	var target_found = false
	if loaded:
		start_cell = IsoMapModel.nearest_walkable_cell(host.map_data, IsoMapModel.spawn_cell(host.map_data) + Vector2i(3, -1))
		var offsets: Array[Vector2i] = [
			Vector2i(1, 0),
			Vector2i(0, 1),
			Vector2i(-1, 0),
			Vector2i(0, -1),
			Vector2i(2, 0),
			Vector2i(0, 2),
		]
		for offset in offsets:
			var candidate = IsoMapModel.nearest_walkable_cell(host.map_data, start_cell + offset)
			var candidate_path: Array[Vector2i] = IsoMapModel.find_path(host.map_data, start_cell, candidate)
			if candidate != start_cell and candidate_path.size() >= 2:
				follow_cell = candidate
				target_found = true
				break
		for offset in offsets:
			var candidate = IsoMapModel.nearest_walkable_cell(host.map_data, follow_cell + offset)
			if candidate != follow_cell:
				click_block_cell = candidate
				break
	if loaded and target_found and host.player != null:
		host.player.global_position = IsoMapModel.grid_to_world(host.map_data, start_cell)
		host.player.clear_move_target()
		host.current_path_cells.clear()
		host.current_path_is_direct = false
		host.has_target_marker = false
		host.has_target_cell = false
	host.server_step_move_authority_valid = false
	var applied: bool = loaded and target_found and host._apply_server_step_move_authority_position({
		"mapId": host.current_map_id,
		"cellX": follow_cell.x,
		"cellY": follow_cell.y,
		"facing": "east",
		"moving": false,
		"authority": "party_follow",
	}, true)
	var immediate_cell = IsoMapModel.world_to_grid(host.map_data, host.player.global_position) if host.player != null and loaded else Vector2i.ZERO
	var smooth_started: bool = (
		applied
		and host.player != null
		and host.player.is_auto_moving()
		and immediate_cell == start_cell
		and host.server_step_move_authority_cell == follow_cell
	)
	host._apply_party_event({
		"party": (host.party_current_state.get("party", {}) as Dictionary).duplicate(true),
	})
	var event_preserved_follow: bool = host.player != null and host.player.is_auto_moving()
	for _step in range(90):
		await host.get_tree().physics_frame
		if host.player != null and not host.player.is_auto_moving():
			break
	var final_cell = IsoMapModel.world_to_grid(host.map_data, host.player.global_position) if host.player != null and loaded else Vector2i.ZERO
	var reached_follow: bool = final_cell == follow_cell
	var click_blocked: bool = false
	if loaded and target_found and click_block_cell != Vector2i.ZERO:
		click_blocked = (
			not host._set_click_move_target_cell(click_block_cell, IsoMapModel.grid_to_world(host.map_data, click_block_cell), click_block_cell)
			and host.world_log_message.find("队伍中由队长带队移动") >= 0
		)
	host.current_account_session = saved_session
	host.party_current_state = saved_party_state
	var status = "ok" if loaded and target_found and smooth_started and event_preserved_follow and reached_follow and click_blocked else "failed"
	print("party member follow check ready: status=%s loaded=%s target=%s smooth=%s event_preserved=%s reached=%s click_blocked=%s start=%s follow=%s final=%s log=%s" % [
		status,
		str(loaded),
		str(target_found),
		str(smooth_started),
		str(event_preserved_follow),
		str(reached_follow),
		str(click_blocked),
		str(start_cell),
		str(follow_cell),
		str(final_cell),
		host.world_log_message.replace("\n", " / "),
	])
	host.get_tree().quit(0 if status == "ok" else 1)

func _run_auto_mouse_click_check() -> void:
	var start_position = host.player.global_position
	var target = IsoMapModel.grid_to_world(host.map_data, IsoMapModel.spawn_cell(host.map_data) + Vector2i(2, -2))
	var event = InputEventMouseButton.new()
	event.button_index = MOUSE_BUTTON_LEFT
	event.pressed = true
	event.position = host._world_to_screen(target)
	host._input(event)
	for _step in range(18):
		await host.get_tree().physics_frame
	var end_position = host.player.global_position
	var moved_right = end_position.x > start_position.x
	var status = "ok" if moved_right else "failed"
