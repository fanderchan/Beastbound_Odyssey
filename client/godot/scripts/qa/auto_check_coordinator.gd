func _run_auto_server_solo_pve_live_check() -> void:
	host.profile_save_enabled = false
	host.auth_auto_bypass = false
	var suffix = str(Time.get_ticks_usec() % 10000000000)
	var username = ("spve%s" % suffix).substr(0, 20)
	var register_response = await host._auto_http_request_spec(ServerAuthClientModel.register_request(
		ServerAuthClientModel.DEFAULT_BASE_URL,
		username,
		"test1234",
		"单人同步号"
	))
	var register_parsed = ServerAuthClientModel.parse_auth_response(int(register_response.get("responseCode", 0)), register_response.get("body", PackedByteArray()) as PackedByteArray)
	var session = register_parsed.get("session", {}) as Dictionary if register_parsed.get("session", {}) is Dictionary else {}
	var register_ok = bool(register_parsed.get("ok", false)) and str(session.get("serverSessionToken", "")).strip_edges() != ""
	var profile_ready = await host._auto_fetch_server_profile_for_session(session)
	var profile_ok = bool(profile_ready.get("ok", false)) and host._auto_server_profile_has_battle_pet(profile_ready)
	var position_response = await host._auto_http_request_spec(ServerAuthClientModel.player_position_update_request(
		ServerAuthClientModel.DEFAULT_BASE_URL,
		str(session.get("serverSessionToken", "")),
		{
			"mapId": "firebud_village_gate",
			"cellX": 15,
			"cellY": 17,
			"facing": "south",
			"moving": false,
		}
	))
	var position_parsed = ServerAuthClientModel.parse_player_position_update_response(int(position_response.get("responseCode", 0)), position_response.get("body", PackedByteArray()) as PackedByteArray)
	var position_ok = bool(position_parsed.get("ok", false))
	host.current_account_session = session
	host.current_account_session["serverBaseUrl"] = ServerAuthClientModel.DEFAULT_BASE_URL
	host.account_authenticated = true
	host.party_current_state = {
		"party": null,
		"incomingInvites": [],
		"maxMembers": 5,
	}
	host.server_profile_sync_state = "ready"
	host.server_battle_state.clear()
	host.server_battle_pending_closed_room.clear()
	var route_ok = host._should_start_server_party_encounter() and not host._can_start_local_encounter_model()
	var encounter_zone = {
		"id": "client_solo_pve_grass",
		"name": "单人同步草丛",
		"selectedWildPet": {
			"formId": "wuli_normal_orange_fire10",
			"name": "单人同步乌力",
			"level": 3,
			"battleStats": {
				"maxHp": 80,
				"attack": 10,
				"defense": 5,
				"quick": 40,
			},
		},
	}
	host._trigger_encounter(encounter_zone)
	var frames = 0
	while frames < 360 and (host.server_party_encounter_request_pending or not host.battle_active):
		frames += 1
		await host.get_tree().process_frame
	var room_value = host.server_battle_state.get("room", null)
	var room = room_value as Dictionary if room_value is Dictionary else {}
	var battle_value = room.get("battle", null)
	var server_battle = battle_value as Dictionary if battle_value is Dictionary else {}
	var participant_ids: Array = room.get("participantAccountIds", []) if room.get("participantAccountIds", []) is Array else []
	var actors: Array = server_battle.get("actors", []) if server_battle.get("actors", []) is Array else []
	var room_id = str(room.get("roomId", ""))
	var server_room_ok = (
		host.battle_active
		and room_id != ""
		and str(host.battle_state.get("serverRoomId", "")) == room_id
		and str(host.battle_state.get("serverRoomMode", "")) == "party_pve"
		and str(room.get("mode", "")) == "party_pve"
		and str(room.get("partyId", "")) == ""
		and participant_ids.size() == 1
		and actors.filter(func(actor): return actor is Dictionary and str((actor as Dictionary).get("side", "")) == "ally").size() >= 2
		and actors.filter(func(actor): return actor is Dictionary and str((actor as Dictionary).get("side", "")) == "enemy").size() == 1
	)
	var message_ok = host.world_log_message.find("队伍遇敌由队长触发") < 0 and host.world_log_message.find("请先登录服务器账号") < 0
	if room_id != "":
		await host._auto_http_request_spec(ServerAuthClientModel.battle_room_leave_request(
			ServerAuthClientModel.DEFAULT_BASE_URL,
			str(session.get("serverSessionToken", "")),
			room_id
		))
	host._end_battle(true)
	host._stop_server_event_stream()
	var status = "ok" if register_ok and profile_ok and position_ok and route_ok and server_room_ok and message_ok else "failed"
	print("server solo pve live check ready: status=%s register=%s profile=%s position=%s route=%s server_room=%s message=%s room=%s participants=%d actors=%d username=%s log=%s" % [
		status,
		str(register_ok),
		str(profile_ok),
		str(position_ok),
		str(route_ok),
		str(server_room_ok),
		str(message_ok),
		room_id,
		participant_ids.size(),
		actors.size(),
		username,
		host.world_log_message.replace("\n", " / "),
	])
	host.get_tree().quit(0 if status == "ok" else 1)

