func _run_auto_server_click_move_live_check() -> void:
	host.profile_save_enabled = false
	var username = host._live_check_username("cma")
	var register_response = await host._auto_http_request_spec(ServerAuthClientModel.register_request(
		ServerAuthClientModel.DEFAULT_BASE_URL,
		username,
		"test1234",
		"步进甲"
	))
	var register_parsed = ServerAuthClientModel.parse_auth_response(int(register_response.get("responseCode", 0)), register_response.get("body", PackedByteArray()) as PackedByteArray)
	var session = register_parsed.get("session", {}) as Dictionary if register_parsed.get("session", {}) is Dictionary else {}
	host.current_account_session = session
	host.current_account_session["serverBaseUrl"] = ServerAuthClientModel.DEFAULT_BASE_URL
	host.account_authenticated = true
	host.server_profile_sync_state = "ready"
	host._close_auth_panel(false)
	host.encounter_active = false
	host.active_encounter_zone.clear()
	host.encounter_zone_step_count = 0
	host.encounter_grace_remaining = 999.0
	var start_cell = IsoMapModel.spawn_cell(host.map_data) + Vector2i(7, -1)
	var goal_cell = IsoMapModel.nearest_walkable_cell(host.map_data, start_cell + Vector2i(3, 0))
	var path_cells: Array[Vector2i] = IsoMapModel.find_path(host.map_data, start_cell, goal_cell)
	if path_cells.size() < 2:
		goal_cell = IsoMapModel.nearest_walkable_cell(host.map_data, start_cell + Vector2i(0, 3))
		path_cells = IsoMapModel.find_path(host.map_data, start_cell, goal_cell)
	var expected_steps = maxi(0, path_cells.size() - 1)
	if host.player != null:
		host.player.global_position = IsoMapModel.grid_to_world(host.map_data, start_cell)
		host.player.clear_move_target()
	host.server_step_move_authority_valid = false
	host._cancel_server_step_move()
	var seed_response = await host._auto_http_request_spec(ServerAuthClientModel.player_position_update_request(
		ServerAuthClientModel.DEFAULT_BASE_URL,
		str(session.get("serverSessionToken", "")),
		{
			"mapId": host.current_map_id,
			"cellX": start_cell.x,
			"cellY": start_cell.y,
			"facing": "east",
			"moving": false,
		}
	))
	var seed_parsed = ServerAuthClientModel.parse_player_position_update_response(int(seed_response.get("responseCode", 0)), seed_response.get("body", PackedByteArray()) as PackedByteArray)
	var seed_ok = bool(seed_parsed.get("ok", false))
	var target_screen = host._world_to_screen(IsoMapModel.grid_to_world(host.map_data, goal_cell))
	host._set_click_move_target(target_screen)
	var guard = 0
	while guard < 900 and (
		host.server_step_move_active
		or host.server_step_move_request_pending
		or host.server_step_move_waiting_for_visual
		or (host.player != null and host.player.is_auto_moving())
	):
		guard += 1
		await host.get_tree().process_frame
	var final_cell = IsoMapModel.world_to_grid(host.map_data, host.player.global_position) if host.player != null else Vector2i.ZERO
	var publish_response = await host._auto_http_request_spec(ServerAuthClientModel.player_position_update_request(
		ServerAuthClientModel.DEFAULT_BASE_URL,
		str(session.get("serverSessionToken", "")),
		{
			"mapId": host.current_map_id,
			"cellX": final_cell.x,
			"cellY": final_cell.y,
			"facing": host.player.get_facing_key() if host.player != null and host.player.has_method("get_facing_key") else "south",
			"moving": false,
		}
	))
	var publish_parsed = ServerAuthClientModel.parse_player_position_update_response(int(publish_response.get("responseCode", 0)), publish_response.get("body", PackedByteArray()) as PackedByteArray)
	var publish_position = publish_parsed.get("position", {}) as Dictionary if publish_parsed.get("position", {}) is Dictionary else {}
	var publish_ok = (
		bool(publish_parsed.get("ok", false))
		and int(publish_position.get("cellX", -999)) == final_cell.x
		and int(publish_position.get("cellY", -999)) == final_cell.y
	)
	var local_click_ok = (
		expected_steps > 0
		and host.server_step_move_request_count == 0
		and host.server_step_move_ack_count == 0
		and host.server_step_move_last_error_code == ""
		and final_cell == goal_cell
		and not host.server_step_move_active
		and not host.server_step_move_request_pending
		and not host.server_step_move_waiting_for_visual
		and host.world_log_message.find("位置已同步") < 0
	)
	var status = "ok" if bool(register_parsed.get("ok", false)) and seed_ok and local_click_ok and publish_ok else "failed"
	var register_body = register_response.get("body", PackedByteArray()) as PackedByteArray
	print("server click move live check ready: status=%s register=%s seed=%s local_click=%s publish=%s expected_steps=%d requests=%d acks=%d final=%s goal=%s error=%s user=%s register_http=%d register_result=%s register_body=%d" % [
		status,
