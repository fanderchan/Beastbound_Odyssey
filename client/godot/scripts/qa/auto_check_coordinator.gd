	host._load_map(GM_10V10_MAP_ID)
	host._start_battle(BattleModel.create_wild_battle({
		"id": "phase112_player_knockaway",
		"name": "Phase112人物击飞",
	}))
	await host.get_tree().process_frame
	var player_started = host.battle_active and not BattleModel.actor_by_id(host.battle_state, BattleModel.PLAYER_ACTOR_ID).is_empty()
	if player_started:
		host.battle_state = BattleModel.apply_battle_event(host.battle_state, {
			"type": "attack",
			"attackerId": "enemy_0",
			"targetId": BattleModel.PLAYER_ACTOR_ID,
			"targetSide": BattleModel.SIDE_ALLY,
			"damage": 10000,
			"speed": 90,
			"sequence": 1,
			"movementStyle": "melee",
			"canLaunch": true,
			"launchMode": "straight",
			"forceDodge": false,
			"forceCritical": false,
		})
	var player_launch_applied = PlayerProgressModel.battle_actor_knocked_away(host.battle_state, BattleModel.PLAYER_ACTOR_ID)
	var player_end_ok = host._battle_state_should_end(host.battle_state)
	var player_result = host._finish_battle_and_return_to_world()
	await host.get_tree().process_frame
	var player_cell = IsoMapModel.world_to_grid(host.map_data, host.player.global_position) if host.player != null else Vector2i.ZERO
	var player_return_ok = (
		map_loaded
		and player_started
		and player_launch_applied
		and player_end_ok
		and str(player_result.get("result", "")) == "defeat"
		and bool(player_result.get("playerKnockedAway", false))
		and bool(player_result.get("returnToRecordPoint", false))
		and host.current_map_id == "firebud_village_gate"
		and player_cell == Vector2i(10, 17)
		and host.world_log_message.find("回到记录点") >= 0
	)

	host.player_profile = PlayerProgressModel.default_profile()
	var active_pet_id = str(host.player_profile.get("activePetInstanceId", ""))
	host._load_map(GM_10V10_MAP_ID)
	host._start_battle(BattleModel.create_wild_battle({
		"id": "phase112_pet_knockaway",
		"name": "Phase112宠物击飞",
	}))
	await host.get_tree().process_frame
	var pet_started = host.battle_active and active_pet_id != "" and not BattleModel.actor_by_id(host.battle_state, BattleModel.PLAYER_PET_ID).is_empty()
	if pet_started:
		host.battle_state = BattleModel.apply_battle_event(host.battle_state, {
			"type": "attack",
			"attackerId": "enemy_0",
			"targetId": BattleModel.PLAYER_PET_ID,
			"targetSide": BattleModel.SIDE_ALLY,
			"damage": 10000,
			"speed": 90,
			"sequence": 2,
			"movementStyle": "melee",
			"canLaunch": true,
			"launchMode": "bounce",
			"forceDodge": false,
			"forceCritical": false,
		})
	var pet_launch_applied = PlayerProgressModel.battle_actor_knocked_away(host.battle_state, BattleModel.PLAYER_PET_ID)
	var pet_result = host._finish_battle_and_return_to_world("escape")
	await host.get_tree().process_frame
	var pet_after = PlayerProgressModel.pet_instance_by_id(host.player_profile, active_pet_id)
	var pet_rest_ok = (
		pet_started
		and pet_launch_applied
		and str(pet_result.get("result", "")) == "escape"
		and bool(pet_result.get("activePetKnockedAway", false))
		and str(pet_after.get("state", "")) == PlayerProgressModel.PET_STATE_REST
		and int(pet_after.get("hp", 1)) == 0
		and str(host.player_profile.get("activePetInstanceId", "")) != active_pet_id
		and host.world_log_message.find("进入休息状态") >= 0
	)

	var enemy_state = BattleModel.create_wild_battle({
		"id": "phase112_enemy_knockaway",
		"name": "Phase112敌方击飞",
	})
	enemy_state = BattleModel.apply_battle_event(enemy_state, {
		"type": "attack",
		"attackerId": BattleModel.PLAYER_ACTOR_ID,
		"targetId": "enemy_0",
		"targetSide": BattleModel.SIDE_ENEMY,
		"damage": 10000,
		"speed": 90,
		"sequence": 3,
		"movementStyle": "melee",
		"canLaunch": true,
		"launchMode": "straight",
		"forceDodge": false,
		"forceCritical": false,
	})
	var enemy_result = PlayerProgressModel.apply_battle_result(PlayerProgressModel.default_profile(), enemy_state)
	var enemy_knocked_ids: Array = enemy_result.get("enemyKnockedAwayActorIds", [])
	var enemy_launch_ok = (
		str(enemy_result.get("result", "")) == "victory"
		and enemy_knocked_ids.has("enemy_0")
		and not bool(enemy_result.get("returnToRecordPoint", true))
	)

	var capture_state = BattleModel.create_wild_battle({
		"id": "phase112_capture_settlement",
		"name": "Phase112捕获结算",
	})
	capture_state = BattleModel.apply_battle_event(capture_state, {
		"type": "capture",
		"attackerId": BattleModel.PLAYER_ACTOR_ID,
		"targetId": "enemy_0",
		"targetSide": BattleModel.SIDE_ENEMY,
		"success": true,
		"speed": 100,
		"sequence": 4,
	})
	var capture_result = PlayerProgressModel.apply_battle_result(PlayerProgressModel.default_profile(), capture_state)
	var captured_pets: Array = capture_result.get("capturedPets", [])
	var capture_ok = (
		str(capture_result.get("result", "")) == "victory"
		and captured_pets.size() == 1
		and capture_result.has("knockedAwayActorIds")
		and not bool(capture_result.get("returnToRecordPoint", true))
	)

	var escape_result = PlayerProgressModel.apply_battle_result(
		PlayerProgressModel.default_profile(),
		BattleModel.create_wild_battle({
			"id": "phase112_escape_settlement",
			"name": "Phase112逃跑结算",
		}),
		"escape"
	)
	var escape_ok = (
		str(escape_result.get("result", "")) == "escape"
		and escape_result.has("knockedAwayActorIds")
		and not bool(escape_result.get("returnToRecordPoint", true))
	)

	var status = "ok" if player_return_ok and pet_rest_ok and enemy_launch_ok and capture_ok and escape_ok else "failed"
	print("battle knockaway result check ready: status=%s player=%s pet=%s enemy=%s capture=%s escape=%s cell=%s player_result=%s pet_state=%s log=%s" % [
		status,
		str(player_return_ok),
		str(pet_rest_ok),
		str(enemy_launch_ok),
		str(capture_ok),
		str(escape_ok),
		str(player_cell),
		str(player_result.get("result", "")),
		str(pet_after.get("state", "")),
		host.world_log_message.replace("\n", " / "),
	])
	host.get_tree().quit(0 if status == "ok" else 1)

func _run_auto_pet_management_check() -> void:
