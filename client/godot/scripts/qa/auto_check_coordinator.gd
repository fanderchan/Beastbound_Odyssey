		str(sleep_ok),
		str(confusion_ok),
		str(stone_ok),
		str(sleep_result.get("eventType", "")),
		str(confusion_result.get("eventType", "")),
		str(stone_result.get("eventType", "")),
	])
	host.get_tree().quit(0 if status == "ok" else 1)

