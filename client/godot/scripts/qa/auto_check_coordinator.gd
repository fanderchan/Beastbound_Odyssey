		str(default_enemy.get("formId", "")) == "wuli_normal_orange_fire10"
		and str(default_enemy.get("name", "")) == "野生乌力"
		and int(default_enemy.get("maxHp", 0)) == 80
		and str(default_state.get("message", "")).find("野生乌力") >= 0
