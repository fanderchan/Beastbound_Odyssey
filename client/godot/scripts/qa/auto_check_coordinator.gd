		var sleep_button = host.battle_command_buttons["defend"] as Button
		var confuse_button = host.battle_command_buttons["item"] as Button
		var stone_button = host.battle_command_buttons["switch_pet"] as Button
		labels_ok = (
			sleep_button != null
			and confuse_button != null
			and stone_button != null
			and sleep_button.text == "技4 催眠粉"
			and confuse_button.text == "技5 迷惑吼"
			and stone_button.text == "技6 石化凝视"
