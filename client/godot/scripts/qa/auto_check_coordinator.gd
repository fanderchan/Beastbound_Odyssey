func _run_auto_battle_reaction_check() -> void:
	var started = host._start_stat_formula_test_battle()
	await host.get_tree().process_frame
	if not started:
		print("battle reaction check ready: status=failed started=false")
		host.get_tree().quit(1)
		return

	var attacker_id = BattleModel.PLAYER_ACTOR_ID
	var target_id = "enemy_front_3"
	host.battle_state = host._set_battle_actor_fields(host.battle_state, target_id, {
		"dodgeRateOverride": 1.0,
		"counterRateOverride": 1.0,
	})
	var target_hp_before = int(BattleModel.actor_by_id(host.battle_state, target_id).get("hp", 0))
	host.battle_state = BattleModel.apply_battle_event(host.battle_state, {
		"type": "attack",
		"attackerId": attacker_id,
		"targetId": target_id,
		"targetSide": BattleModel.SIDE_ENEMY,
		"damage": BattleModel.attack_damage_preview_for(host.battle_state, attacker_id, target_id),
		"speed": 100,
		"sequence": 10,
		"movementStyle": "melee",
		"canLaunch": true,
	})
	var dodge_target_hp_after = int(BattleModel.actor_by_id(host.battle_state, target_id).get("hp", 0))
	var counter_event = host.battle_state.get("lastCounterEvent", {})
	var dodge_ok = bool(host.battle_state.get("lastDodged", false)) and dodge_target_hp_after == target_hp_before and counter_event is Dictionary and not (counter_event as Dictionary).is_empty()

	host.battle_state = host._set_battle_actor_fields(host.battle_state, attacker_id, {
		"dodgeRateOverride": 1.0,
		"counterRateOverride": 1.0,
	})
	if counter_event is Dictionary:
		host.battle_state = BattleModel.apply_battle_event(host.battle_state, (counter_event as Dictionary))
	var counter_no_chain_ok = bool(host.battle_state.get("lastDodged", false)) and not bool(host.battle_state.get("lastCounterTriggered", false)) and int(host.battle_state.get("lastDamage", 0)) == 0

	started = host._start_stat_formula_test_battle()
	await host.get_tree().process_frame
	var critical_target_id = "enemy_front_4"
	var normal_damage = BattleModel.attack_damage_preview_for(host.battle_state, attacker_id, critical_target_id)
	host.battle_state = BattleModel.apply_battle_event(host.battle_state, {
		"type": "attack",
		"attackerId": attacker_id,
		"targetId": critical_target_id,
		"targetSide": BattleModel.SIDE_ENEMY,
		"damage": normal_damage,
		"speed": 100,
		"sequence": 20,
		"movementStyle": "melee",
		"canLaunch": false,
		"forceDodge": false,
		"forceCritical": true,
	})
	var critical_damage = int(host.battle_state.get("lastDamage", 0))
	var critical_ok = bool(host.battle_state.get("lastCritical", false)) and critical_damage > normal_damage

	started = host._start_stat_formula_test_battle()
	await host.get_tree().process_frame
	host.battle_state = host._set_battle_actor_fields(host.battle_state, target_id, {
		"dodgeRateOverride": 1.0,
	})
	var combo_damage = BattleModel.attack_damage_preview_for(host.battle_state, "ally_speed_fast", target_id) + BattleModel.attack_damage_preview_for(host.battle_state, "ally_attack_high", target_id) + 8
	host.battle_state = BattleModel.apply_battle_event(host.battle_state, {
		"type": "combo_attack",
		"attackerId": "ally_speed_fast",
		"participantIds": ["ally_speed_fast", "ally_attack_high"],
		"targetId": target_id,
		"targetSide": BattleModel.SIDE_ENEMY,
		"damage": combo_damage,
		"speed": 130,
		"sequence": 30,
		"movementStyle": "melee_combo",
		"canLaunch": false,
	})
	var combo_unavoidable_ok = not bool(host.battle_state.get("lastDodged", false)) and int(host.battle_state.get("lastDamage", 0)) == combo_damage

	started = host._start_stat_formula_test_battle()
	await host.get_tree().process_frame
	var wild_combo_event = {
		"type": "attack",
		"attackerId": target_id,
		"targetId": attacker_id,
		"targetSide": BattleModel.SIDE_ALLY,
	}
	var wild_combo_chance = BattleModel.combo_chance_for_event(host.battle_state, wild_combo_event)
	host.battle_state = host._set_battle_actor_fields(host.battle_state, target_id, {"kind": "pet"})
	var pvp_combo_chance = BattleModel.combo_chance_for_event(host.battle_state, wild_combo_event)
	host.battle_state = host._set_battle_actor_fields(host.battle_state, target_id, {"comboBonusRate": 0.15})
	var bonus_combo_chance = BattleModel.combo_chance_for_event(host.battle_state, wild_combo_event)
	var combo_rate_ok = absf(wild_combo_chance - 0.20) < 0.001 and absf(pvp_combo_chance - 0.50) < 0.001 and absf(bonus_combo_chance - 0.65) < 0.001

	var status = "ok" if dodge_ok and counter_no_chain_ok and critical_ok and combo_unavoidable_ok and combo_rate_ok else "failed"
	print("battle reaction check ready: status=%s dodge=%s counter_no_chain=%s critical=%s combo_unavoidable=%s combo_rate=%s wild_rate=%.2f pvp_rate=%.2f bonus_rate=%.2f normal_damage=%d critical_damage=%d combo_damage=%d" % [
		status,
		str(dodge_ok),
		str(counter_no_chain_ok),
		str(critical_ok),
		str(combo_unavoidable_ok),
		str(combo_rate_ok),
		wild_combo_chance,
		pvp_combo_chance,
		bonus_combo_chance,
		normal_damage,
		critical_damage,
		combo_damage,
	])
	host.get_tree().quit(0 if status == "ok" else 1)

func _run_auto_battle_result_check() -> void:
	host.profile_save_enabled = false
	host.player_profile = PlayerProgressModel.default_profile()
	var profile_player = host.player_profile.get("player", {}) as Dictionary
	var before_exp = int(profile_player.get("exp", 0))
	var before_pet_count = 0
	var before_instances = host.player_profile.get("petInstances", [])
	if before_instances is Array:
		before_pet_count = (before_instances as Array).size()
	host._start_battle(BattleModel.create_wild_battle({
		"id": "battle_result_check",
		"name": "结算验证",
	}))
	await host.get_tree().process_frame
	var target_id = BattleModel.living_enemy_id(host.battle_state)
	var target_actor = BattleModel.actor_by_id(host.battle_state, target_id)
	var started = host.battle_active and target_id != "" and not target_actor.is_empty()
	if started:
		host.battle_state = BattleModel.apply_battle_event(host.battle_state, {
			"type": "capture",
			"attackerId": BattleModel.PLAYER_ACTOR_ID,
			"targetId": target_id,
			"targetSide": BattleModel.SIDE_ENEMY,
			"success": true,
			"speed": 100,
			"sequence": 1,
		})
	var result = host._finish_battle_and_return_to_world()
	await host.get_tree().process_frame
	var after_player = host.player_profile.get("player", {}) as Dictionary
	var after_instances = host.player_profile.get("petInstances", [])
	var after_pet_count = (after_instances as Array).size() if after_instances is Array else 0
	var captured_instance_ok = false
	if after_instances is Array:
		for value in after_instances:
			if not (value is Dictionary):
				continue
			var instance = value as Dictionary
			if str(instance.get("instanceId", "")).begins_with("pet_captured_") and str(instance.get("formId", "")).begins_with("wuli_"):
				captured_instance_ok = true
				break
	var log_text = host.battle_log_label.text if host.battle_log_label != null else ""
	var result_ok = str(result.get("result", "")) == "victory"
	var exited_ok = not host.battle_active and host.player != null and host.player.visible
	var log_ok = (
		host.world_log_message.find("获得") >= 0
		and host.world_log_message.find("捕获") >= 0
		and host.world_log_message.find("战力") >= 0
		and log_text == host.world_log_message
	)
	var exp_ok = int(after_player.get("exp", 0)) > before_exp or int(after_player.get("level", 1)) > int(profile_player.get("level", 1))
	var pet_count_ok = after_pet_count == before_pet_count + 1
	var panel_ok = host.battle_message_panel != null and host.battle_message_panel.visible and not host.battle_command_panel.visible
	var status = "ok" if started and result_ok and exited_ok and log_ok and exp_ok and pet_count_ok and captured_instance_ok and panel_ok else "failed"
	print("battle result check ready: status=%s started=%s result=%s exited=%s log=%s exp=%s pet_count=%s captured=%s panel=%s before_exp=%d after_exp=%d before_pets=%d after_pets=%d log_text=%s" % [
		status,
		str(started),
		str(result_ok),
		str(exited_ok),
		str(log_ok),
		str(exp_ok),
		str(pet_count_ok),
		str(captured_instance_ok),
		str(panel_ok),
		before_exp,
		int(after_player.get("exp", 0)),
		before_pet_count,
		after_pet_count,
		host.world_log_message.replace("\n", " / "),
	])
	host.get_tree().quit(0 if status == "ok" else 1)

func _run_auto_battle_knockaway_result_check() -> void:
	host.profile_save_enabled = false
	host.world_log_history.clear()
	host.world_log_message = ""
	var map_loaded = host._load_map(GM_10V10_MAP_ID)

	host.player_profile = PlayerProgressModel.with_record_point(
