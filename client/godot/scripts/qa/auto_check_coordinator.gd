	))
	var register_parsed = ServerAuthClientModel.parse_auth_response(int(register_response.get("responseCode", 0)), register_response.get("body", PackedByteArray()) as PackedByteArray)
	var session = register_parsed.get("session", {}) as Dictionary if register_parsed.get("session", {}) is Dictionary else {}
	host.current_account_session = session
	host.current_account_session["serverBaseUrl"] = ServerAuthClientModel.DEFAULT_BASE_URL
	host.account_authenticated = true
	host.server_profile_sync_state = "ready"
	host._close_auth_panel(false)
	host.encounter_active = false
	host.active_encounter_zone.clear()
	host.encounter_zone_step_count = 0
	host.encounter_grace_remaining = 999.0
	var stale_cell = IsoMapModel.nearest_walkable_cell(host.map_data, IsoMapModel.spawn_cell(host.map_data) + Vector2i(7, -1))
	var server_cell = IsoMapModel.nearest_walkable_cell(host.map_data, stale_cell + Vector2i(1, 0))
	if server_cell == stale_cell:
		server_cell = IsoMapModel.nearest_walkable_cell(host.map_data, stale_cell + Vector2i(0, 1))
	var goal_cell = IsoMapModel.nearest_walkable_cell(host.map_data, server_cell + Vector2i(3, 0))
	var server_path_cells: Array[Vector2i] = IsoMapModel.find_path(host.map_data, server_cell, goal_cell)
	if server_path_cells.size() < 2:
		goal_cell = IsoMapModel.nearest_walkable_cell(host.map_data, server_cell + Vector2i(0, 3))
		server_path_cells = IsoMapModel.find_path(host.map_data, server_cell, goal_cell)
	var expected_acks = maxi(0, server_path_cells.size() - 1)
	if host.player != null:
		host.player.global_position = IsoMapModel.grid_to_world(host.map_data, stale_cell)
		host.player.clear_move_target()
	host.server_step_move_authority_valid = false
	host._cancel_server_step_move()
	var seed_response = await host._auto_http_request_spec(ServerAuthClientModel.player_position_update_request(
		ServerAuthClientModel.DEFAULT_BASE_URL,
		str(session.get("serverSessionToken", "")),
		{
			"mapId": host.current_map_id,
			"cellX": server_cell.x,
			"cellY": server_cell.y,
			"facing": "east",
			"moving": false,
		}
	))
	var seed_parsed = ServerAuthClientModel.parse_player_position_update_response(int(seed_response.get("responseCode", 0)), seed_response.get("body", PackedByteArray()) as PackedByteArray)
	var seed_ok = bool(seed_parsed.get("ok", false))
	host.server_step_move_authority_cell = stale_cell
	host.server_step_move_authority_valid = true
	host.server_step_move_sync_retry_count = 0
	var target_screen = host._world_to_screen(IsoMapModel.grid_to_world(host.map_data, goal_cell))
	host._set_click_move_target(target_screen)
	var guard = 0
	while guard < 900 and (
		host.server_step_move_active
		or host.server_step_move_request_pending
		or host.server_step_move_waiting_for_visual
		or (host.player != null and host.player.is_auto_moving())
	):
		guard += 1
		await host.get_tree().process_frame
	var final_cell = IsoMapModel.world_to_grid(host.map_data, host.player.global_position) if host.player != null else Vector2i.ZERO
	var authority_cell = host.server_step_move_authority_cell
	var reject_recovered = (
		expected_acks > 0
		and host.server_step_move_sync_retry_count >= 1
		and host.server_step_move_request_count >= expected_acks + 1
		and host.server_step_move_ack_count >= expected_acks
		and host.server_step_move_last_error_code == ""
		and final_cell == goal_cell
		and authority_cell == goal_cell
		and not host.server_step_move_active
		and not host.server_step_move_request_pending
		and not host.server_step_move_waiting_for_visual
	)
	var status = "ok" if bool(register_parsed.get("ok", false)) and seed_ok and reject_recovered else "failed"
	var register_body = register_response.get("body", PackedByteArray()) as PackedByteArray
	print("server click move reject live check ready: status=%s register=%s seed=%s recovered=%s expected_acks=%d requests=%d acks=%d retries=%d stale=%s server=%s final=%s authority=%s goal=%s error=%s user=%s register_http=%d register_result=%s register_body=%d" % [
		status,
		str(bool(register_parsed.get("ok", false))),
		str(seed_ok),
		str(reject_recovered),
		expected_acks,
		host.server_step_move_request_count,
		host.server_step_move_ack_count,
		host.server_step_move_sync_retry_count,
		str(stale_cell),
		str(server_cell),
		str(final_cell),
		str(authority_cell),
		str(goal_cell),
		host.server_step_move_last_error_code,
		username,
		int(register_response.get("responseCode", 0)),
		str(bool(register_response.get("ok", false))),
		register_body.size(),
	])
	host.get_tree().quit(0 if status == "ok" else 1)

