	host._close_pet_panel()

	host._open_interaction_dialog(stable_keeper)
	await host.get_tree().process_frame
	var dialog_text = host.dialog_body_label.text if host.dialog_body_label != null else ""
	var dialog_ok = (
		loaded
		and not stable_keeper.is_empty()
		and host._dialog_is_open()
		and host.dialog_option_button != null
		and host.dialog_option_button.text == "完成"
		and dialog_text.find("远程兽栏") >= 0
		and dialog_text.find("奖励：远程兽栏能力") >= 0
	)
	host._confirm_dialog_action()
	await host.get_tree().process_frame
	var unlocked_ok = (
		PlayerProgressModel.has_remote_stable(host.player_profile)
		and PlayerProgressModel.active_quest_id(host.player_profile) == remote_unlock_active_id
		and host.world_log_message.find("完成任务「远程兽栏」") >= 0
		and host.world_log_message.find("远程兽栏能力") >= 0
	)

	host.pet_selected_instance_id = "pet_bui_tough"
	host._open_pet_panel(false)
	await host.get_tree().process_frame
	var remote_button_ok = (
		host.pet_panel != null
		and host.pet_panel.visible
		and not host.pet_panel_stable_access_override
		and host.pet_stable_button != null
		and host.pet_stable_button.visible
		and not host.pet_stable_button.disabled
		and host.pet_stable_button.text == "存入"
	)
	host._on_pet_stable_pressed()
	await host.get_tree().process_frame
	var remote_pet = PlayerProgressModel.pet_instance_by_id(host.player_profile, "pet_bui_tough")
	var remote_store_ok = str(remote_pet.get("state", "")) == PlayerProgressModel.PET_STATE_STORAGE
	host._close_pet_panel()

	var already_unlocked = PlayerProgressModel.with_unlocked_ability(PlayerProgressModel.with_rebirth_count(PlayerProgressModel.default_profile(), 4), PlayerProgressModel.ABILITY_REMOTE_STABLE)
	host.player_profile = already_unlocked
