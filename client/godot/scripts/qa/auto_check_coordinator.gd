	var speed_standby_to_battle_ready = host.pet_state_cycle_button != null and not host.pet_state_cycle_button.disabled and host.pet_state_cycle_button.text == "战斗"
	host._on_pet_state_cycle_pressed()
	await host.get_tree().process_frame
	var speed_battle = str(PlayerProgressModel.pet_instance_by_id(host.player_profile, "pet_bui_speed").get("state", "")) == PlayerProgressModel.PET_STATE_BATTLE
	var active_after = PlayerProgressModel.active_pet(host.player_profile)
