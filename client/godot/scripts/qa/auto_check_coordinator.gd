	var first_result_detail = host.battle_result_detail_label.text if host.battle_result_detail_label != null else ""
	var first_result_panel_ok = (
		host.battle_result_panel != null
		and host.battle_result_panel.visible
		and first_result_title.begins_with("战斗")
		and first_result_title.find("切磋") < 0
		and first_result_detail.find("已逃离战斗。") >= 0
		and first_result_detail.find("对手：") < 0
	)
	var first_message_text = str(first_result.get("message", ""))
	var first_message_ok = first_message_text.find("已逃离战斗") >= 0 and first_message_text.find("切磋") < 0 and host.world_log_message.find("切磋") < 0
	var first_cleanup_ok = bool(first_leave.get("ok", false)) and not host.battle_active and first_result_panel_ok and first_message_ok
	if host.battle_result_panel != null:
		host._close_battle_result_panel(false)
	var rejoin_invite_response = await host._auto_http_request_spec(ServerAuthClientModel.party_invite_request(
		ServerAuthClientModel.DEFAULT_BASE_URL,
		str(leader_session.get("serverSessionToken", "")),
		member_username
	))
	var rejoin_invite_parsed = ServerAuthClientModel.parse_party_action_response(int(rejoin_invite_response.get("responseCode", 0)), rejoin_invite_response.get("body", PackedByteArray()) as PackedByteArray)
	var rejoin_invite = rejoin_invite_parsed.get("invite", {}) as Dictionary if rejoin_invite_parsed.get("invite", {}) is Dictionary else {}
	var rejoin_accept_response = await host._auto_http_request_spec(ServerAuthClientModel.party_invite_accept_request(
		ServerAuthClientModel.DEFAULT_BASE_URL,
		str(member_session.get("serverSessionToken", "")),
		str(rejoin_invite.get("inviteId", ""))
	))
	var rejoin_accept_parsed = ServerAuthClientModel.parse_party_action_response(int(rejoin_accept_response.get("responseCode", 0)), rejoin_accept_response.get("body", PackedByteArray()) as PackedByteArray)
	var rejoin_party = rejoin_accept_parsed.get("party", {}) as Dictionary if rejoin_accept_parsed.get("party", {}) is Dictionary else {}
	var rejoin_members: Array = rejoin_party.get("members", []) if rejoin_party.get("members", []) is Array else []
	var rejoin_ok = bool(rejoin_invite_parsed.get("ok", false)) and bool(rejoin_accept_parsed.get("ok", false)) and rejoin_members.size() == 2
	if rejoin_ok:
		host.party_current_state = {
			"party": rejoin_party,
			"incomingInvites": [],
			"maxMembers": 5,
		}
	var second_encounter_response = await host._auto_http_request_spec(ServerAuthClientModel.party_battle_encounter_request(
		ServerAuthClientModel.DEFAULT_BASE_URL,
		str(leader_session.get("serverSessionToken", "")),
		encounter_zone,
		2
	))
	var second_encounter = ServerAuthClientModel.parse_battle_action_response(int(second_encounter_response.get("responseCode", 0)), second_encounter_response.get("body", PackedByteArray()) as PackedByteArray)
	var second_room = second_encounter.get("room", {}) as Dictionary if second_encounter.get("room", {}) is Dictionary else {}
	var second_room_id = str(second_room.get("roomId", ""))
	var second_start_ok = bool(second_encounter.get("ok", false)) and second_room_id != "" and host._apply_server_battle_room_state(second_room, true)
	var second_battle = second_room.get("battle", {}) as Dictionary if second_room.get("battle", {}) is Dictionary else {}
	var actors: Array = second_battle.get("actors", []) if second_battle.get("actors", []) is Array else []
	var leader_player_id = ""
	var leader_pet_id = ""
	var member_player_id = ""
	var member_pet_id = ""
	var enemy_id = ""
	for value in actors:
		if not (value is Dictionary):
			continue
		var actor = value as Dictionary
		var actor_id = str(actor.get("actorId", ""))
		if str(actor.get("side", "")) == "enemy" and enemy_id == "":
			enemy_id = actor_id
		elif str(actor.get("username", "")) == leader_username and str(actor.get("kind", "")) == "player":
			leader_player_id = actor_id
		elif str(actor.get("username", "")) == leader_username and str(actor.get("kind", "")) == "pet":
			leader_pet_id = actor_id
		elif str(actor.get("username", "")) == member_username and str(actor.get("kind", "")) == "player":
			member_player_id = actor_id
		elif str(actor.get("username", "")) == member_username and str(actor.get("kind", "")) == "pet":
			member_pet_id = actor_id
	var actor_ids_ok = leader_player_id != "" and leader_pet_id != "" and member_player_id != "" and member_pet_id != "" and enemy_id != ""
	var leader_player_command_response = await host._auto_http_request_spec(ServerAuthClientModel.battle_command_submit_request(
		ServerAuthClientModel.DEFAULT_BASE_URL,
		str(leader_session.get("serverSessionToken", "")),
		second_room_id,
		{
			"round": 1,
			"actorId": leader_player_id,
			"actionId": "attack",
			"targetActorId": enemy_id,
		}
	))
	var leader_pet_command_response = await host._auto_http_request_spec(ServerAuthClientModel.battle_command_submit_request(
		ServerAuthClientModel.DEFAULT_BASE_URL,
		str(leader_session.get("serverSessionToken", "")),
		second_room_id,
		{
			"round": 1,
			"actorId": leader_pet_id,
			"actionId": "pet_attack",
			"targetActorId": enemy_id,
		}
	))
	var member_player_command_response = await host._auto_http_request_spec(ServerAuthClientModel.battle_command_submit_request(
		ServerAuthClientModel.DEFAULT_BASE_URL,
		str(member_session.get("serverSessionToken", "")),
		second_room_id,
		{
			"round": 1,
			"actorId": member_player_id,
			"actionId": "defend",
		}
	))
	var member_pet_command_response = await host._auto_http_request_spec(ServerAuthClientModel.battle_command_submit_request(
		ServerAuthClientModel.DEFAULT_BASE_URL,
		str(member_session.get("serverSessionToken", "")),
		second_room_id,
		{
			"round": 1,
			"actorId": member_pet_id,
			"actionId": "pet_defend",
		}
	))
	var leader_player_command = ServerAuthClientModel.parse_battle_command_response(int(leader_player_command_response.get("responseCode", 0)), leader_player_command_response.get("body", PackedByteArray()) as PackedByteArray)
	var leader_pet_command = ServerAuthClientModel.parse_battle_command_response(int(leader_pet_command_response.get("responseCode", 0)), leader_pet_command_response.get("body", PackedByteArray()) as PackedByteArray)
	var member_player_command = ServerAuthClientModel.parse_battle_command_response(int(member_player_command_response.get("responseCode", 0)), member_player_command_response.get("body", PackedByteArray()) as PackedByteArray)
	var member_pet_command = ServerAuthClientModel.parse_battle_command_response(int(member_pet_command_response.get("responseCode", 0)), member_pet_command_response.get("body", PackedByteArray()) as PackedByteArray)
	var resolved_room = member_pet_command.get("room", {}) as Dictionary if member_pet_command.get("room", {}) is Dictionary else {}
	var resolved_turn = member_pet_command.get("turn", {}) as Dictionary if member_pet_command.get("turn", {}) is Dictionary else {}
	var commands_ok = (
		bool(leader_player_command.get("ok", false))
		and bool(leader_pet_command.get("ok", false))
		and bool(member_player_command.get("ok", false))
		and bool(member_pet_command.get("ok", false))
		and str(resolved_turn.get("kind", "")) == "battle_event_list"
	)
	var server_round = 0
	if resolved_room.get("battle", {}) is Dictionary:
		server_round = int((resolved_room.get("battle", {}) as Dictionary).get("round", 0))
	var local_before_round = int(host.battle_state.get("round", 0))
	var local_before_phase = str(host.battle_state.get("phase", ""))
	host.battle_state["round"] = 1
	host.battle_state["phase"] = "round_events"
	host.battle_event_queue.clear()
	host.battle_current_event.clear()
	host.battle_action_timer = 0.0
	host.battle_event_advance_pending = false
	host.server_battle_last_playback_turn_key = host._server_battle_turn_key(resolved_turn)
	host.server_battle_command_request_active = false
	host.server_battle_state_poll_request_active = false
	host.server_battle_state["room"] = second_room.duplicate(true)
	var active_poll_ok = host._server_battle_should_poll_waiting_state()
	host._apply_polled_server_battle_room(resolved_room, second_room_id)
	var playback_started_ok = host._server_battle_event_playback_active() or str(host.battle_state.get("phase", "")) == "round_events"
	var frames = 0
	while frames < 720 and (host._server_battle_event_playback_active() or int(host.battle_state.get("round", 1)) < 2):
		frames += 1
		await host.get_tree().process_frame
	var local_round_after = int(host.battle_state.get("round", 0))
	var local_phase_after = str(host.battle_state.get("phase", ""))
	var sync_ok = host.battle_active and local_round_after >= 2 and server_round >= 2 and local_phase_after == "command"
	var playback_or_sync_ok = playback_started_ok or sync_ok
	var idle_round_events_sync_ok = active_poll_ok and sync_ok
	var member_round2_player_response = await host._auto_http_request_spec(ServerAuthClientModel.battle_command_submit_request(
		ServerAuthClientModel.DEFAULT_BASE_URL,
		str(member_session.get("serverSessionToken", "")),
		second_room_id,
		{
			"round": 2,
			"actorId": member_player_id,
			"actionId": "defend",
		}
	))
	var member_round2_pet_response = await host._auto_http_request_spec(ServerAuthClientModel.battle_command_submit_request(
		ServerAuthClientModel.DEFAULT_BASE_URL,
		str(member_session.get("serverSessionToken", "")),
		second_room_id,
		{
			"round": 2,
			"actorId": member_pet_id,
			"actionId": "pet_defend",
		}
	))
	var member_round2_player = ServerAuthClientModel.parse_battle_command_response(int(member_round2_player_response.get("responseCode", 0)), member_round2_player_response.get("body", PackedByteArray()) as PackedByteArray)
	var member_round2_pet = ServerAuthClientModel.parse_battle_command_response(int(member_round2_pet_response.get("responseCode", 0)), member_round2_pet_response.get("body", PackedByteArray()) as PackedByteArray)
	var member_round2_room = member_round2_pet.get("room", {}) as Dictionary if member_round2_pet.get("room", {}) is Dictionary else {}
	if member_round2_room.is_empty():
		member_round2_room = member_round2_player.get("room", {}) as Dictionary if member_round2_player.get("room", {}) is Dictionary else {}
	var member_round2_commands_ok = bool(member_round2_player.get("ok", false)) and bool(member_round2_pet.get("ok", false)) and not member_round2_room.is_empty()
	var actor_missing_response = await host._auto_http_request_spec(ServerAuthClientModel.battle_command_submit_request(
		ServerAuthClientModel.DEFAULT_BASE_URL,
		str(member_session.get("serverSessionToken", "")),
		second_room_id,
		{
			"round": 2,
			"actorId": "missing_actor_for_sync_check",
			"actionId": "defend",
		}
	))
	var actor_missing = ServerAuthClientModel.parse_battle_command_response(int(actor_missing_response.get("responseCode", 0)), actor_missing_response.get("body", PackedByteArray()) as PackedByteArray)
	var actor_missing_room = actor_missing.get("room", {}) as Dictionary if actor_missing.get("room", {}) is Dictionary else {}
	var actor_missing_room_ok = not bool(actor_missing.get("ok", false)) and str(actor_missing.get("code", "")) == "battle_command_actor_missing" and not actor_missing_room.is_empty()
	var auto_waiting_lock_ok = false
	if member_round2_commands_ok:
		host.server_battle_state["room"] = member_round2_room.duplicate(true)
		host._sync_server_battle_room_scene(false)
		host.battle_state["phase"] = "command"
		host._set_battle_command_owner("player")
		host.battle_auto_attack_enabled = true
		host.battle_auto_attack_delay = 0.0
		host.server_battle_command_request_active = false
		host._update_battle_auto_attack(0.25)
		await host.get_tree().process_frame
		auto_waiting_lock_ok = (
			not host.server_battle_command_request_active
			and str(host.battle_state.get("phase", "")) == "server_waiting"
			and str(host.battle_state.get("message", "")).find("等待") >= 0
		)
		host.battle_auto_attack_enabled = false
	var second_no_popup_ok = host.battle_result_panel == null or not host.battle_result_panel.visible
	var result_ui_ok = first_result_panel_ok and second_no_popup_ok
	if second_room_id != "":
		await host._auto_http_request_spec(ServerAuthClientModel.battle_room_leave_request(
			ServerAuthClientModel.DEFAULT_BASE_URL,
			str(member_session.get("serverSessionToken", "")),
			second_room_id
		))
	host._end_battle(true)
	host._stop_server_event_stream()
	var status = "ok" if register_ok and profile_ok and positions_ok and party_ok and first_start_ok and escape_preview_started_ok and escape_preview_motion_ok and first_cleanup_ok and rejoin_ok and second_start_ok and actor_ids_ok and commands_ok and idle_round_events_sync_ok and playback_or_sync_ok and member_round2_commands_ok and actor_missing_room_ok and auto_waiting_lock_ok and result_ui_ok else "failed"
	print("server party pve sync live check ready: status=%s register=%s profile=%s positions=%s party=%s first_start=%s escape_preview=%s/%s first_cleanup=%s rejoin=%s second_start=%s actors=%s commands=%s round2_commands=%s actor_missing_room=%s auto_waiting_lock=%s active_poll=%s idle_round_events_sync=%s playback=%s playback_or_sync=%s sync=%s result_ui=%s first_panel=%s second_no_popup=%s first_message=%s first_panel_detail=%s local_before=%d/%s server_round=%d local_after=%d/%s room=%s leader=%s member=%s" % [
		status,
		str(register_ok),
		str(profile_ok),
		str(positions_ok),
		str(party_ok),
		str(first_start_ok),
		str(escape_preview_started_ok),
		str(escape_preview_motion_ok),
		str(first_cleanup_ok),
		str(rejoin_ok),
		str(second_start_ok),
		str(actor_ids_ok),
		str(commands_ok),
		str(member_round2_commands_ok),
		str(actor_missing_room_ok),
		str(auto_waiting_lock_ok),
		str(active_poll_ok),
		str(idle_round_events_sync_ok),
		str(playback_started_ok),
		str(playback_or_sync_ok),
		str(sync_ok),
		str(result_ui_ok),
		str(first_result_panel_ok),
		str(second_no_popup_ok),
		first_message_text.replace("\n", " / "),
		("%s / %s" % [first_result_title, first_result_detail]).replace("\n", " / "),
		local_before_round,
		local_before_phase,
		server_round,
		local_round_after,
		local_phase_after,
		second_room_id,
		leader_username,
		member_username,
	])
	host.get_tree().quit(0 if status == "ok" else 1)

func _run_auto_server_battle_stale_room_check() -> void:
	host.profile_save_enabled = false
	host.current_account_session = {
		"accountId": "acc_stale_self",
		"username": "stale_self",
		"displayName": "断线测试号",
		"authSource": ServerAuthClientModel.SOURCE_SERVER,
		"serverSessionToken": "token_stale",
		"serverBaseUrl": ServerAuthClientModel.DEFAULT_BASE_URL,
		"profileSavePath": "user://server_accounts/stale_self/player_profile.json",
	}
	host.account_authenticated = true
	var room = {
		"status": "ready",
		"roomId": "stale_room",
		"seed": "stale_seed",
		"battle": {
			"round": 2,
			"phase": "command",
			"actors": [
				{
					"actorId": "stale_self_player",
					"accountId": "acc_stale_self",
					"username": "stale_self",
					"displayName": "断线测试号",
					"side": "challenger",
					"kind": "player",
					"level": 31,
					"hp": 120,
					"maxHp": 120,
					"attack": 22,
					"defense": 8,
					"quick": 58,
					"slotNumber": 3,
				},
				{
					"actorId": "stale_enemy_player",
					"accountId": "acc_stale_enemy",
					"username": "stale_enemy",
					"displayName": "断线对手",
					"side": "opponent",
					"kind": "player",
					"level": 31,
					"hp": 118,
					"maxHp": 118,
					"attack": 23,
					"defense": 8,
					"quick": 56,
					"slotNumber": 3,
				},
			],
			"requiredActorIds": ["stale_self_player", "stale_enemy_player"],
			"submittedActorIds": [],
		},
	}
	var started_ok = host._apply_server_battle_room_state(room, true)
	var before_ok = started_ok and host._battle_is_server_authority() and host.battle_active and str(host.battle_state.get("serverRoomId", "")) == "stale_room"
	host._clear_stale_server_battle_room("切磋房间已失效，已回到地图。")
	await host.get_tree().process_frame
	var cleared_ok = (
		not host.battle_active
		and host.battle_state.is_empty()
		and not host.server_battle_command_request_active
		and host.server_battle_pending_closed_room.is_empty()
		and not (host.server_battle_state.get("room", null) is Dictionary)
		and host.world_log_message.find("切磋房间已失效") >= 0
	)
	var ui_ok = (
		host.player != null
		and host.player.visible
		and (host.battle_command_panel == null or not host.battle_command_panel.visible)
		and (host.action_bar == null or host.action_bar.visible)
	)
	var status = "ok" if before_ok and cleared_ok and ui_ok else "failed"
	print("server battle stale room check ready: status=%s before=%s cleared=%s ui=%s battle_active=%s room_is_dict=%s message=%s" % [
		status,
		str(before_ok),
		str(cleared_ok),
		str(ui_ok),
		str(host.battle_active),
		str(host.server_battle_state.get("room", null) is Dictionary),
		host.world_log_message.replace("\n", " / "),
	])
	host.get_tree().quit(0 if status == "ok" else 1)

func _run_auto_server_battle_pet_snapshot_live_check() -> void:
	host.profile_save_enabled = false
	var suffix = str(Time.get_ticks_usec() % 10000000000)
	var challenger_username = "bpa%s" % suffix
	var opponent_username = "bpb%s" % suffix
	challenger_username = challenger_username.substr(0, mini(20, challenger_username.length()))
	opponent_username = opponent_username.substr(0, mini(20, opponent_username.length()))
	var challenger_register = await host._auto_http_request_spec(ServerAuthClientModel.register_request(
		ServerAuthClientModel.DEFAULT_BASE_URL,
		challenger_username,
		"test1234",
		"宠物甲"
	))
	var opponent_register = await host._auto_http_request_spec(ServerAuthClientModel.register_request(
		ServerAuthClientModel.DEFAULT_BASE_URL,
		opponent_username,
		"test1234",
		"宠物乙"
	))
	var challenger_parsed = ServerAuthClientModel.parse_auth_response(int(challenger_register.get("responseCode", 0)), challenger_register.get("body", PackedByteArray()) as PackedByteArray)
	var opponent_parsed = ServerAuthClientModel.parse_auth_response(int(opponent_register.get("responseCode", 0)), opponent_register.get("body", PackedByteArray()) as PackedByteArray)
	var challenger_session = challenger_parsed.get("session", {}) as Dictionary if challenger_parsed.get("session", {}) is Dictionary else {}
	var opponent_session = opponent_parsed.get("session", {}) as Dictionary if opponent_parsed.get("session", {}) is Dictionary else {}
	var register_ok = bool(challenger_parsed.get("ok", false)) and bool(opponent_parsed.get("ok", false))
	var challenger_profile_ready = await host._auto_fetch_server_profile_for_session(challenger_session)
	var opponent_profile_ready = await host._auto_fetch_server_profile_for_session(opponent_session)
	var challenger_pet_ids = host._auto_server_profile_pet_ids(challenger_profile_ready)
	var opponent_pet_ids = host._auto_server_profile_pet_ids(opponent_profile_ready)
	var challenger_active_pet_id = str(challenger_pet_ids.get("activePetId", ""))
	var opponent_active_pet_id = str(opponent_pet_ids.get("activePetId", ""))
	var profile_ok = (
		bool(challenger_profile_ready.get("ok", false))
		and bool(opponent_profile_ready.get("ok", false))
		and challenger_active_pet_id != ""
		and opponent_active_pet_id != ""
	)
	var battle_cell = IsoMapModel.spawn_cell(host.map_data) + Vector2i(8, -1)
	var challenger_position_response = await host._auto_http_request_spec(ServerAuthClientModel.player_position_update_request(
		ServerAuthClientModel.DEFAULT_BASE_URL,
		str(challenger_session.get("serverSessionToken", "")),
		{
			"mapId": host.current_map_id,
			"cellX": battle_cell.x,
			"cellY": battle_cell.y,
			"facing": "east",
			"moving": false,
		}
	))
	var opponent_position_response = await host._auto_http_request_spec(ServerAuthClientModel.player_position_update_request(
		ServerAuthClientModel.DEFAULT_BASE_URL,
		str(opponent_session.get("serverSessionToken", "")),
		{
			"mapId": host.current_map_id,
			"cellX": battle_cell.x + 1,
			"cellY": battle_cell.y,
			"facing": "west",
			"moving": false,
		}
	))
	var challenger_position_parsed = ServerAuthClientModel.parse_player_position_update_response(int(challenger_position_response.get("responseCode", 0)), challenger_position_response.get("body", PackedByteArray()) as PackedByteArray)
	var opponent_position_parsed = ServerAuthClientModel.parse_player_position_update_response(int(opponent_position_response.get("responseCode", 0)), opponent_position_response.get("body", PackedByteArray()) as PackedByteArray)
	var positions_ok = bool(challenger_position_parsed.get("ok", false)) and bool(opponent_position_parsed.get("ok", false))
	host.current_account_session = opponent_session
	host.current_account_session["serverBaseUrl"] = ServerAuthClientModel.DEFAULT_BASE_URL
	host.account_authenticated = true
	host.server_profile_sync_state = "ready"
	host.server_battle_state.clear()
	host.server_battle_pending_closed_room.clear()
	host.server_event_last_seq = 0
	host.server_event_seen.clear()
	host._start_server_event_stream_if_needed()
	var frames = 0
	while frames < 720 and host.server_event_state != "open" and not host._server_event_type_seen("events.ready"):
		frames += 1
		await host.get_tree().process_frame
	var stream_ready = host.server_event_state == "open" or host._server_event_type_seen("events.ready")
	host.server_event_seen.clear()
	var invite_response = await host._auto_http_request_spec(ServerAuthClientModel.battle_invite_request(
		ServerAuthClientModel.DEFAULT_BASE_URL,
		str(challenger_session.get("serverSessionToken", "")),
		opponent_username
	))
	var invite_parsed = ServerAuthClientModel.parse_battle_action_response(int(invite_response.get("responseCode", 0)), invite_response.get("body", PackedByteArray()) as PackedByteArray)
	var invite = invite_parsed.get("invite", {}) as Dictionary if invite_parsed.get("invite", {}) is Dictionary else {}
	var invite_id = str(invite.get("inviteId", ""))
	frames = 0
	while frames < 720 and not host._battle_invite_seen(invite_id):
