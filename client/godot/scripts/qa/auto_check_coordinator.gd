		and challenger_pet_actor_id != ""
		and opponent_player_actor_id != ""
		and opponent_pet_actor_id != ""
		and initial_pet_hp > 0
		and initial_item_ok
	)
	host._on_battle_command_pressed("item")
	await host.get_tree().process_frame
	var heal_all_button = host.battle_command_buttons.get("attack") as Button
	var heal_button = host.battle_command_buttons.get("spirit") as Button
	var poison_button = host.battle_command_buttons.get("capture") as Button
	var poison_all_button = host.battle_command_buttons.get("defend") as Button
	var cleanse_button = host.battle_command_buttons.get("item") as Button
	var meat_button = host.battle_command_buttons.get("switch_pet") as Button
	var menu_ok = (
		host.battle_command_owner == "item"
		and heal_all_button != null
		and not heal_all_button.disabled
		and heal_button != null
		and not heal_button.disabled
		and poison_button != null
		and not poison_button.disabled
		and poison_all_button != null
		and not poison_all_button.disabled
		and cleanse_button != null
		and not cleanse_button.disabled
		and meat_button != null
		and not meat_button.disabled
	)
	host._on_battle_command_pressed("attack")
	await host.get_tree().process_frame
	var target_mode_ok = host.battle_target_mode == "enemy" or host.battle_target_mode == ""
	var frames = 0
	while frames < 720 and host.server_battle_command_request_active:
		frames += 1
		await host.get_tree().process_frame
	var room_after_item = host.server_battle_state.get("room", {}) as Dictionary if host.server_battle_state.get("room", {}) is Dictionary else {}
	var battle_after_item = room_after_item.get("battle", {}) as Dictionary if room_after_item.get("battle", {}) is Dictionary else {}
	var submitted_after_item: Array = battle_after_item.get("submittedActorIds", []) if battle_after_item.get("submittedActorIds", []) is Array else []
	var item_submit_ok = (
		not host.server_battle_command_request_active
		and submitted_after_item.has(challenger_player_actor_id)
		and BattleModel.item_count(host.battle_state, BattleModel.ITEM_HEAL_ALL) == initial_heal_all_count
		and host.battle_command_owner == "pet"
	)
	await host._submit_server_battle_pet_command("defend", "", BattleModel.PET_SKILL_DEFEND)
	frames = 0
	while frames < 720 and host.server_battle_command_request_active:
		frames += 1
		await host.get_tree().process_frame
	var pet_submit_ok = not host.server_battle_command_request_active
	var opponent_player_command_response = await host._auto_http_request_spec(ServerAuthClientModel.battle_command_submit_request(
		ServerAuthClientModel.DEFAULT_BASE_URL,
		str(opponent_session.get("serverSessionToken", "")),
		room_id,
		{
			"round": 1,
			"actorId": opponent_player_actor_id,
			"actionId": "defend",
		}
	))
	var opponent_player_command = ServerAuthClientModel.parse_battle_command_response(int(opponent_player_command_response.get("responseCode", 0)), opponent_player_command_response.get("body", PackedByteArray()) as PackedByteArray)
	var opponent_pet_command_response = await host._auto_http_request_spec(ServerAuthClientModel.battle_command_submit_request(
		ServerAuthClientModel.DEFAULT_BASE_URL,
		str(opponent_session.get("serverSessionToken", "")),
		room_id,
		{
			"round": 1,
			"actorId": opponent_pet_actor_id,
			"actionId": "pet_defend",
		}
	))
	var opponent_pet_command = ServerAuthClientModel.parse_battle_command_response(int(opponent_pet_command_response.get("responseCode", 0)), opponent_pet_command_response.get("body", PackedByteArray()) as PackedByteArray)
	var remote_commands_ok = bool(opponent_player_command.get("ok", false)) and bool(opponent_pet_command.get("ok", false))
	var remote_turn = opponent_pet_command.get("turn", {}) as Dictionary if opponent_pet_command.get("turn", {}) is Dictionary else {}
	var remote_room = opponent_pet_command.get("room", {}) as Dictionary if opponent_pet_command.get("room", {}) is Dictionary else {}
	if not remote_turn.is_empty() and not remote_room.is_empty() and host._battle_is_server_authority() and str(host.battle_state.get("serverRoomId", "")).strip_edges() == str(remote_room.get("roomId", "")).strip_edges():
		host.server_battle_state["room"] = remote_room.duplicate(true)
		host._sync_server_battle_snapshot_fields_during_playback(remote_room)
		host._play_server_battle_event_list(remote_turn)
	frames = 0
	while frames < 900 and (not host._battle_turn_resolved(room_id, 1) or host._server_battle_event_playback_active() or int(host.battle_state.get("round", 1)) < 2):
		frames += 1
		await host.get_tree().process_frame
	await host.get_tree().process_frame
	var last_event_list = host.battle_state.get("lastServerEventList", {}) as Dictionary if host.battle_state.get("lastServerEventList", {}) is Dictionary else {}
	var events: Array = last_event_list.get("events", []) if last_event_list.get("events", []) is Array else []
	var item_event_ok = false
	for event_value in events:
		if not (event_value is Dictionary):
			continue
		var event = event_value as Dictionary
		if str(event.get("eventType", "")) != "item_heal_all":
			continue
		var item_targets: Array = event.get("targets", []) if event.get("targets", []) is Array else []
		var pet_target_ok = false
		for target_value in item_targets:
			if not (target_value is Dictionary):
				continue
			var target_summary = target_value as Dictionary
			if str(target_summary.get("targetActorId", "")) != challenger_pet_actor_id:
				continue
			var hp_before = int(target_summary.get("hpBefore", 0))
			var hp_after = int(target_summary.get("hpAfter", 0))
			pet_target_ok = (
				str(target_summary.get("targetKind", "")) == "pet"
				and hp_before == initial_pet_hp
				and hp_after >= hp_before
				and int(target_summary.get("healed", 0)) == hp_after - hp_before
			)
			break
		item_event_ok = (
			str(event.get("itemId", "")) == BattleModel.ITEM_HEAL_ALL
			and int(event.get("remainingItemCount", -1)) == initial_heal_all_count - 1
			and pet_target_ok
		)
		break
	var healed_pet_hp = int(BattleModel.actor_by_id(host.battle_state, "ally_pet").get("hp", 0))
	var local_item_ok = BattleModel.item_count(host.battle_state, BattleModel.ITEM_HEAL_ALL) == initial_heal_all_count - 1
	var round_ok = int(host.battle_state.get("round", 1)) >= 2
	var playback_ok = item_event_ok and healed_pet_hp >= initial_pet_hp and host.battle_last_round_event_types.has("item_heal_all") and local_item_ok and round_ok
	var status = "ok" if register_ok and profile_ok and positions_ok and invite_ok and accepted_room_applied and ready_ok and menu_ok and target_mode_ok and item_submit_ok and pet_submit_ok and remote_commands_ok and playback_ok else "failed"
	print("server battle item live check ready: status=%s register=%s profile=%s positions=%s invite=%s room_apply=%s ready=%s menu=%s target_mode=%s item_submit=%s pet_submit=%s remote=%s item_event=%s healed_hp=%d local_item=%s round=%s room_id=%s challenger=%s opponent=%s" % [
		status,
		str(register_ok),
		str(profile_ok),
		str(positions_ok),
		str(invite_ok),
		str(accepted_room_applied),
		str(ready_ok),
		str(menu_ok),
		str(target_mode_ok),
		str(item_submit_ok),
		str(pet_submit_ok),
		str(remote_commands_ok),
		str(item_event_ok),
		healed_pet_hp,
		str(local_item_ok),
		str(round_ok),
		room_id,
		challenger_username,
		opponent_username,
	])
	if room_id != "":
		await host._auto_http_request_spec(ServerAuthClientModel.battle_room_leave_request(
			ServerAuthClientModel.DEFAULT_BASE_URL,
			str(challenger_session.get("serverSessionToken", "")),
			room_id
		))
	host.get_tree().quit(0 if status == "ok" else 1)

func _run_auto_server_profile_sync_check() -> void:
	host.profile_save_enabled = false
	var original_save_path = PlayerProgressModel.current_save_path()
	var temp_save_path = "user://server_profile_sync_check/player_profile.json"
	PlayerProgressModel.set_active_save_path(temp_save_path)
	var session = {
		"username": "syncuser",
		"displayName": "同步猎人",
		"role": AccountAuthModel.ROLE_PLAYER,
		"effectiveRole": AccountAuthModel.EFFECTIVE_ROLE_PLAYER,
		"gmPluginInstalled": false,
		"profileSavePath": "user://server_accounts/syncuser/player_profile.json",
		"authSource": ServerAuthClientModel.SOURCE_SERVER,
		"serverBaseUrl": "http://127.0.0.1:8787",
		"serverSessionToken": "token_sync",
		"serverProfileSummary": {
			"playerId": "player_sync",
			"profileRevision": 0,
			"storageMode": "server_document",
			"serverAuthority": "profile_document",
		},
	}
	host.current_account_session = session
	host.account_authenticated = true
	host.player_profile = PlayerProgressModel.default_profile()
	host._apply_server_profile_summary(session.get("serverProfileSummary", {}) as Dictionary)
	host.server_profile_sync_state = "ready"
	var revision_zero_ok = host.server_profile_sync_expected_revision == 0
	host._queue_server_profile_upload()
	var no_upload_ok = (
		host.server_profile_sync_state == "ready"
		and host.server_profile_sync_pending_kind == ""
		and not host.server_profile_sync_dirty
		and host.server_profile_sync_expected_revision == 0
	)
	var upload_denied_response = ServerAuthClientModel.parse_profile_upload_response(403, JSON.stringify({
		"ok": false,
		"code": "profile_upload_denied",
		"message": "角色档案由服务器专用接口写入，禁止客户端整档上传。",
	}).to_utf8_buffer())
	var upload_denied_ok = (
		not bool(upload_denied_response.get("ok", true))
		and str(upload_denied_response.get("code", "")) == "profile_upload_denied"
	)
	host.server_profile_sync_state = "uploading"
	host.server_profile_sync_dirty = true
	host.server_profile_sync_pull_queued = false
	host.server_profile_sync_pending_kind = ""
	var legacy_conflict_response = ServerAuthClientModel.parse_profile_upload_response(409, JSON.stringify({
		"ok": false,
		"code": "revision_conflict",
		"message": "服务器档案已更新，请重新登录或重新拉取档案。",
		"profileSummary": {
			"playerId": "player_sync",
			"profileRevision": 99,
		},
	}).to_utf8_buffer())
	host._apply_server_profile_upload_result(legacy_conflict_response)
	var upload_conflict_disabled_ok = (
		host.server_profile_sync_state == "ready"
		and host.server_profile_sync_pending_kind == ""
		and not host.server_profile_sync_dirty
		and not host.server_profile_sync_pull_queued
		and host.server_profile_sync_message.find("整档上传已禁用") >= 0
		and host.server_profile_sync_expected_revision == 0
	)
	var remote_profile = PlayerProgressModel.default_profile()
	var remote_player = remote_profile.get("player", {}) as Dictionary
	remote_player["name"] = "云端猎人"
	remote_profile["player"] = remote_player
	var pull_response = ServerAuthClientModel.parse_profile_response(200, JSON.stringify({
		"ok": true,
		"profile": remote_profile,
		"profileSummary": {
			"playerId": "player_sync",
			"profileRevision": 2,
			"storageMode": "server_document",
			"serverAuthority": "profile_document",
		},
	}).to_utf8_buffer())
	host._apply_server_profile_pull_result(pull_response)
	var pulled_player = host.player_profile.get("player", {}) as Dictionary if host.player_profile.get("player", {}) is Dictionary else {}
	var pull_ok = str(pulled_player.get("name", "")) == "云端猎人" and host.server_profile_sync_expected_revision == 2
	host.server_profile_sync_pull_queued = false
	host.server_profile_sync_deferred_pull_result.clear()
	host.server_profile_sync_state = "ready"
	host._open_shop_panel(ShopCatalogModel.DEFAULT_SHOP_ID)
	host._queue_server_profile_pull()
	var panel_queue_defer_ok = (
		host.shop_panel != null
		and host.shop_panel.visible
		and host.server_profile_sync_pull_queued
		and host.server_profile_sync_state == "ready"
		and host.server_profile_sync_pending_kind == ""
	)
	host.server_profile_sync_pull_queued = false
	host._close_shop_panel()
	var panel_profile = PlayerProgressModel.default_profile()
	var panel_player = panel_profile.get("player", {}) as Dictionary
	panel_player["name"] = "面板猎人"
	panel_profile["player"] = panel_player
	host.player_profile = PlayerProgressModel.normalize_profile(panel_profile)
	host.server_profile_sync_expected_revision = 2
	host.server_profile_sync_state = "ready"
	host.server_profile_sync_pull_queued = false
	host.server_profile_sync_deferred_pull_result.clear()
	host._open_shop_panel(ShopCatalogModel.DEFAULT_SHOP_ID)
	var deferred_remote_profile = PlayerProgressModel.default_profile()
	var deferred_player = deferred_remote_profile.get("player", {}) as Dictionary
	deferred_player["name"] = "延迟猎人"
	deferred_remote_profile["player"] = deferred_player
	var deferred_response = ServerAuthClientModel.parse_profile_response(200, JSON.stringify({
		"ok": true,
		"profile": deferred_remote_profile,
		"profileSummary": {
			"playerId": "player_sync",
			"profileRevision": 3,
			"storageMode": "server_document",
			"serverAuthority": "profile_document",
		},
	}).to_utf8_buffer())
	host._apply_server_profile_pull_result(deferred_response)
	var deferred_hold_player = host.player_profile.get("player", {}) as Dictionary if host.player_profile.get("player", {}) is Dictionary else {}
	var panel_response_defer_ok = (
		host.shop_panel != null
		and host.shop_panel.visible
		and str(deferred_hold_player.get("name", "")) == "面板猎人"
		and not host.server_profile_sync_deferred_pull_result.is_empty()
		and host.server_profile_sync_expected_revision == 2
	)
	host._close_shop_panel()
	var deferred_applied_player = host.player_profile.get("player", {}) as Dictionary if host.player_profile.get("player", {}) is Dictionary else {}
	var panel_deferred_apply_ok = (
		str(deferred_applied_player.get("name", "")) == "延迟猎人"
		and host.server_profile_sync_expected_revision == 3
		and host.server_profile_sync_deferred_pull_result.is_empty()
	)
	host._open_shop_panel(ShopCatalogModel.DEFAULT_SHOP_ID)
	var timeout_remote_profile = PlayerProgressModel.default_profile()
	var timeout_player_profile = timeout_remote_profile.get("player", {}) as Dictionary
	timeout_player_profile["name"] = "超时猎人"
	timeout_remote_profile["player"] = timeout_player_profile
	var timeout_response = ServerAuthClientModel.parse_profile_response(200, JSON.stringify({
		"ok": true,
		"profile": timeout_remote_profile,
		"profileSummary": {
			"playerId": "player_sync",
			"profileRevision": 4,
			"storageMode": "server_document",
			"serverAuthority": "profile_document",
		},
	}).to_utf8_buffer())
	host._apply_server_profile_pull_result(timeout_response)
	host._update_deferred_server_profile_pull(ServerSyncCoordinator.PROFILE_PULL_DEFER_TIMEOUT_SECONDS + 0.1)
	var timeout_applied_player = host.player_profile.get("player", {}) as Dictionary if host.player_profile.get("player", {}) is Dictionary else {}
	var panel_deferred_timeout_ok = (
		host.shop_panel != null
		and host.shop_panel.visible
		and str(timeout_applied_player.get("name", "")) == "超时猎人"
		and host.server_profile_sync_expected_revision == 4
		and host.server_profile_sync_deferred_pull_result.is_empty()
		and host.server_profile_sync_deferred_pull_elapsed == 0.0
	)
	host._close_shop_panel()
	var panel_defer_ok = panel_queue_defer_ok and panel_response_defer_ok and panel_deferred_apply_ok and panel_deferred_timeout_ok
	var session_expired_response = ServerAuthClientModel.parse_profile_response(401, JSON.stringify({
		"ok": false,
		"code": "session_expired",
		"message": "登录会话已过期。",
	}).to_utf8_buffer())
	host._apply_server_profile_pull_result(session_expired_response)
	var session_expired_ok = (
		not host.account_authenticated
		and host.auth_panel != null
		and host.auth_panel.visible
		and host.auth_message_label != null
		and host.auth_message_label.text.find("登录会话已过期") >= 0
		and host.auth_username_input != null
		and host.auth_username_input.text == "syncuser"
		and host.world_log_message.find("登录会话已过期") >= 0
	)
	var status = "ok" if revision_zero_ok and no_upload_ok and upload_denied_ok and upload_conflict_disabled_ok and pull_ok and panel_defer_ok and session_expired_ok else "failed"
	print("server profile sync check ready: status=%s rev0=%s no_upload=%s denied=%s conflict_disabled=%s pull=%s panel_defer=%s panel_timeout=%s session_expired=%s state=%s rev=%d" % [
		status,
		str(revision_zero_ok),
		str(no_upload_ok),
		str(upload_denied_ok),
		str(upload_conflict_disabled_ok),
		str(pull_ok),
		str(panel_defer_ok),
		str(panel_deferred_timeout_ok),
		str(session_expired_ok),
		host.server_profile_sync_state,
		host.server_profile_sync_expected_revision,
	])
	PlayerProgressModel.set_active_save_path(original_save_path)
	host.get_tree().quit(0 if status == "ok" else 1)

