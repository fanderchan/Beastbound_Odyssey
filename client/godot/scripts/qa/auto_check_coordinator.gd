func _run_auto_battle_target_check() -> void:
	var loaded: bool = host._load_map("firebud_village_gate", "from_training_yard")
	var zones = EncounterModel.encounter_zones(host.map_data)
	var zone_found: bool = loaded and not zones.is_empty()
	if zone_found:
		host._start_battle(BattleModel.create_formation_preview_battle(zones[0] as Dictionary))
	await host.get_tree().process_frame
	var target_id = "enemy_front_5"
	var target_actor = BattleModel.actor_by_id(host.battle_state, target_id)
	var target_screen = host._world_to_screen(host._battle_slot_world_position(str(target_actor.get("slotId", "")))) if not target_actor.is_empty() else Vector2.ZERO
	var initially_unselected = host.battle_selected_target_id == "" and host.battle_hover_target_id == ""
	host._on_battle_command_pressed("attack")
	host._update_battle_hover_at_screen_point(target_screen)
	var hover_ok = host.battle_hover_target_id == target_id
	var selected_by_tap = host._select_battle_target_at_screen_point(target_screen)
	var selection_ok = str(host.battle_pending_player_command.get("targetId", "")) == target_id
	var target_before = int(BattleModel.actor_by_id(host.battle_state, target_id).get("hp", 0))
	var first_id = "enemy_back_1"
	var first_before = int(BattleModel.actor_by_id(host.battle_state, first_id).get("hp", 0))
	host._auto_submit_pet_attack_if_needed()
	var guard = 0
	var target_after = target_before
	while guard < 300 and host.battle_active:
		guard += 1
		await host.get_tree().process_frame
		target_after = int(BattleModel.actor_by_id(host.battle_state, target_id).get("hp", 0))
		if target_after < target_before:
			break
	var first_after = int(BattleModel.actor_by_id(host.battle_state, first_id).get("hp", 0))
	var selected_damaged = target_before > 0 and target_after < target_before
	var first_unchanged = first_after == first_before
	var status = "ok" if loaded and zone_found and initially_unselected and hover_ok and selected_by_tap and selection_ok and selected_damaged and first_unchanged else "failed"
	print("battle target check ready: status=%s loaded=%s zone_found=%s initially_unselected=%s hover_ok=%s selected_by_tap=%s selection_ok=%s selected=%s target_before=%d target_after=%d first_before=%d first_after=%d" % [
		status,
		str(loaded),
		str(zone_found),
		str(initially_unselected),
		str(hover_ok),
		str(selected_by_tap),
		str(selection_ok),
		str(host.battle_pending_player_command.get("targetId", "")),
		target_before,
		target_after,
		first_before,
		first_after,
	])
	host.get_tree().quit(0 if status == "ok" else 1)

func _run_auto_battle_round_check() -> void:
	var loaded: bool = host._load_map("firebud_village_gate", "from_training_yard")
	var zones = EncounterModel.encounter_zones(host.map_data)
	var zone_found: bool = loaded and not zones.is_empty()
	if zone_found:
		host._start_battle(BattleModel.create_formation_preview_battle(zones[0] as Dictionary))
	await host.get_tree().process_frame
	var target_id = "enemy_front_5"
	var target_actor = BattleModel.actor_by_id(host.battle_state, target_id)
	var target_screen = host._world_to_screen(host._battle_slot_world_position(str(target_actor.get("slotId", "")))) if not target_actor.is_empty() else Vector2.ZERO
	host._on_battle_command_pressed("attack")
	host._update_battle_hover_at_screen_point(target_screen)
	var selected_by_tap = host._select_battle_target_at_screen_point(target_screen)
	var target_before = int(BattleModel.actor_by_id(host.battle_state, target_id).get("hp", 0))
	var enemy_count_before = BattleModel.living_actor_count(host.battle_state, BattleModel.SIDE_ENEMY)
	var ally_hp_before = host._battle_side_total_hp(BattleModel.SIDE_ALLY)
	host._auto_submit_pet_attack_if_needed()
	await host.get_tree().process_frame
	var locked_after_attack = host._battle_commands_locked()
	var guard = 0
	while guard < 2400 and host.battle_active and host._battle_commands_locked():
		guard += 1
		await host.get_tree().process_frame
	var target_after = int(BattleModel.actor_by_id(host.battle_state, target_id).get("hp", 0))
	var enemy_count_after = BattleModel.living_actor_count(host.battle_state, BattleModel.SIDE_ENEMY)
	var ally_hp_after = host._battle_side_total_hp(BattleModel.SIDE_ALLY)
	var returned_to_command = host.battle_active and not host._battle_commands_locked()
	var target_was_hit = target_before > 0 and target_after < target_before
	var enemy_removed_or_damaged = target_was_hit or enemy_count_after < enemy_count_before
	var ally_was_hit = ally_hp_after < ally_hp_before
	var enemy_target_spread = host._unique_string_count(host.battle_last_round_enemy_target_ids) > 1
	var enough_events = host.battle_last_round_applied_events >= 12
	var status = "ok" if loaded and zone_found and selected_by_tap and locked_after_attack and returned_to_command and enemy_removed_or_damaged and ally_was_hit and enemy_target_spread and enough_events else "failed"
	print("battle round check ready: status=%s loaded=%s zone_found=%s selected_by_tap=%s locked_after_attack=%s returned_to_command=%s target_before=%d target_after=%d enemy_count_before=%d enemy_count_after=%d ally_hp_before=%d ally_hp_after=%d enemy_target_spread=%s applied_events=%d" % [
		status,
		str(loaded),
		str(zone_found),
		str(selected_by_tap),
		str(locked_after_attack),
		str(returned_to_command),
		target_before,
		target_after,
		enemy_count_before,
		enemy_count_after,
		ally_hp_before,
		ally_hp_after,
		str(enemy_target_spread),
		host.battle_last_round_applied_events,
	])
	host.get_tree().quit(0 if status == "ok" else 1)

func _run_auto_battle_command_timer_check() -> void:
	host.profile_save_enabled = false
	host.player_profile = PlayerProgressModel.default_profile()
	var loaded: bool = host._load_map("firebud_village_gate", "from_training_yard")
	var zones = EncounterModel.encounter_zones(host.map_data)
	var zone_found: bool = loaded and not zones.is_empty()
	if zone_found:
		host._start_battle(BattleModel.create_formation_preview_battle(zones[0] as Dictionary))
	await host.get_tree().process_frame
	var initial_round_ok = host.battle_round_label != null and host.battle_round_label.text == "第 1 回合"
	var initial_timer_ok = host.battle_timer_label != null and host.battle_timer_label.text == "99秒"
	var timer_visible_ok = host.battle_round_panel != null and host.battle_round_panel.visible and host.battle_timer_panel != null and host.battle_timer_panel.visible
	var saved_battle_state: Dictionary = host.battle_state.duplicate(true)
	var saved_countdown_remaining = host.battle_command_countdown_remaining
	var saved_countdown_last_second = host.battle_command_countdown_last_second
	var deadline_unix := int(Time.get_unix_time_from_system()) + 6
	var deadline_dict := Time.get_datetime_dict_from_unix_time(deadline_unix)
	var deadline_text := "%04d-%02d-%02dT%02d:%02d:%02d.000Z" % [
		int(deadline_dict.get("year", 1970)),
		int(deadline_dict.get("month", 1)),
		int(deadline_dict.get("day", 1)),
		int(deadline_dict.get("hour", 0)),
		int(deadline_dict.get("minute", 0)),
		int(deadline_dict.get("second", 0)),
	]
	var waiting_state: Dictionary = saved_battle_state.duplicate(true)
	waiting_state["serverAuthority"] = true
	waiting_state["phase"] = "server_waiting"
	waiting_state["serverRoom"] = {"battle": {"commandDeadlineAt": deadline_text}}
	host.battle_state = waiting_state
	host.battle_command_countdown_last_second = -1
	host._update_battle_command_countdown(0.0)
	var waiting_first_second := int(ceilf(host.battle_command_countdown_remaining))
	var waiting_visible_initial = host.battle_timer_panel != null and host.battle_timer_panel.visible
	await host.get_tree().create_timer(1.15).timeout
	host._update_battle_command_countdown(0.0)
	var waiting_second_second := int(ceilf(host.battle_command_countdown_remaining))
	var waiting_timer_moves = waiting_visible_initial and waiting_second_second < waiting_first_second
	host.battle_state["phase"] = "round_events"
	host._sync_battle_round_timer_labels(true)
	host._layout_hud()
	var round_events_timer_hidden = host.battle_timer_panel != null and not host.battle_timer_panel.visible
	host.battle_state = saved_battle_state
	host.battle_command_countdown_remaining = saved_countdown_remaining
	host.battle_command_countdown_last_second = saved_countdown_last_second
	host._sync_battle_round_timer_labels(true)
	host._layout_hud()
	host.battle_command_countdown_remaining = 0.04
	host.battle_command_countdown_last_second = -1
	var guard = 0
	while guard < 120 and host.battle_active and not host._battle_commands_locked():
		guard += 1
		await host.get_tree().process_frame
	var auto_started_round = host.battle_active and host._battle_commands_locked() and str(host.battle_state.get("phase", "")) == "round_events"
	var default_round_events = host.battle_action_timer > 0.0 or not host.battle_event_queue.is_empty() or not host.battle_current_event.is_empty()
	guard = 0
	while guard < 2400 and host.battle_active and host._battle_commands_locked():
		guard += 1
		await host.get_tree().process_frame
	var returned_to_command = host.battle_active and not host._battle_commands_locked()
	var second_round_ok = int(host.battle_state.get("round", 0)) >= 2 and host.battle_round_label != null and host.battle_round_label.text == "第 2 回合"
	var timer_reset_ok = host.battle_timer_label != null and host.battle_timer_label.text == "99秒"
	var status = "ok" if loaded and zone_found and initial_round_ok and initial_timer_ok and timer_visible_ok and waiting_timer_moves and round_events_timer_hidden and auto_started_round and default_round_events and returned_to_command and second_round_ok and timer_reset_ok else "failed"
	print("battle command timer check ready: status=%s loaded=%s zone_found=%s visible=%s initial_round=%s initial_timer=%s waiting_moves=%s round_events_hidden=%s auto_started=%s default_events=%s returned=%s second_round=%s timer_reset=%s label_round=%s label_timer=%s waiting_first=%d waiting_second=%d" % [
		status,
		str(loaded),
		str(zone_found),
		str(timer_visible_ok),
		str(initial_round_ok),
		str(initial_timer_ok),
		str(waiting_timer_moves),
		str(round_events_timer_hidden),
		str(auto_started_round),
		str(default_round_events),
		str(returned_to_command),
		str(second_round_ok),
		str(timer_reset_ok),
		host.battle_round_label.text if host.battle_round_label != null else "",
		host.battle_timer_label.text if host.battle_timer_label != null else "",
		waiting_first_second,
		waiting_second_second,
	])
	host.get_tree().quit(0 if status == "ok" else 1)

func _run_auto_battle_speed_check() -> void:
	var loaded: bool = host._load_map("firebud_village_gate", "from_training_yard")
	var previous_multiplier = host.gm_battle_speed_multiplier
	var movement_speed_ok = false
	var normal_walk_distance = 0.0
	var fast_walk_distance = 0.0
	if loaded and host.player != null:
		var start_position = host.player.global_position
		var target_position = start_position + Vector2(480.0, 0.0)
		var previous_grace = host.encounter_grace_remaining
		host.encounter_grace_remaining = 999.0
		host._set_gm_speed_multiplier(GM_BATTLE_SPEED_MIN)
		host.player.global_position = start_position
		host.player.clear_move_target()
		host.player.set_move_target(target_position)
		for _step in range(8):
			await host.get_tree().physics_frame
		normal_walk_distance = host.player.global_position.distance_to(start_position)
		host.player.global_position = start_position
		host.player.clear_move_target()
		host._set_gm_speed_multiplier(5)
		host.player.set_move_target(target_position)
		for _step in range(8):
			await host.get_tree().physics_frame
		fast_walk_distance = host.player.global_position.distance_to(start_position)
		host.player.clear_move_target()
		host._set_gm_speed_multiplier(GM_BATTLE_SPEED_MIN)
		host.encounter_grace_remaining = previous_grace
		movement_speed_ok = fast_walk_distance > normal_walk_distance * 1.8
	var zones = EncounterModel.encounter_zones(host.map_data)
	var zone_found: bool = loaded and not zones.is_empty()
	if zone_found:
		host._start_battle(BattleModel.create_formation_preview_battle(zones[0] as Dictionary))
	await host.get_tree().process_frame
	host._set_gm_speed_multiplier(GM_BATTLE_SPEED_MIN)
	var events = BattleModel.build_command_round_events(host.battle_state, "attack", "enemy_front_5")
	var sorted = not events.is_empty()
	var saw_ally = false
	var saw_enemy = false
	var mixed_opening = false
	var previous_speed = 100000
	var order: Array[String] = []
	var enemy_target_ids: Array[String] = []
	for event in events:
		var speed = int(event.get("speed", 0))
		if speed > previous_speed:
			sorted = false
		previous_speed = speed
		var actor_id = str(event.get("attackerId", ""))
		var actor = BattleModel.actor_by_id(host.battle_state, actor_id)
		var side = str(actor.get("side", ""))
		order.append("%s:%d" % [actor_id, speed])
		if side == BattleModel.SIDE_ALLY:
			saw_ally = true
			if saw_enemy:
				mixed_opening = true
		elif side == BattleModel.SIDE_ENEMY:
			saw_enemy = true
			enemy_target_ids.append(str(event.get("targetId", "")))
			if saw_ally:
				mixed_opening = true
	var enemy_targets_spread = host._unique_string_count(enemy_target_ids) > 1
	host.battle_current_event = {"type": "defend"}
	host.battle_current_event_duration = 1.0
	host.battle_event_advance_pending = false
	host.battle_action_timer = 1.0
	host._update_battle_animation(0.1)
	var normal_animation_ok = absf(host.battle_action_timer - 0.9) <= 0.001
	host._set_gm_speed_multiplier(5)
	host.battle_current_event = {"type": "defend"}
	host.battle_current_event_duration = 1.0
	host.battle_event_advance_pending = false
	host.battle_action_timer = 1.0
	host._update_battle_animation(0.1)
	var fast_animation_ok = absf(host.battle_action_timer - 0.5) <= 0.001
	host.battle_state["phase"] = "command"
	host.battle_current_event.clear()
	host.battle_current_event_duration = 0.0
	host.battle_event_queue.clear()
	host.battle_enemy_response_pending = false
	host.battle_end_pending = false
	host.battle_action_timer = 0.0
	host.battle_auto_attack_enabled = true
	host.battle_auto_attack_delay = 1.0
	host._update_battle_auto_attack(0.1)
	var fast_auto_delay_ok = absf(host.battle_auto_attack_delay - 0.5) <= 0.001
	host.battle_auto_attack_enabled = false
	host._set_gm_speed_multiplier(previous_multiplier)
	var speed_gear_ok = normal_animation_ok and fast_animation_ok and fast_auto_delay_ok
	var status = "ok" if loaded and zone_found and movement_speed_ok and sorted and saw_ally and saw_enemy and mixed_opening and enemy_targets_spread and speed_gear_ok else "failed"
	print("battle speed check ready: status=%s loaded=%s zone_found=%s world_speed=%s normal_walk=%.2f fast_walk=%.2f sorted=%s saw_ally=%s saw_enemy=%s mixed=%s enemy_targets_spread=%s gear=%s normal_anim=%s fast_anim=%s fast_auto_delay=%s order=%s" % [
		status,
		str(loaded),
		str(zone_found),
		str(movement_speed_ok),
		normal_walk_distance,
		fast_walk_distance,
		str(sorted),
		str(saw_ally),
		str(saw_enemy),
		str(mixed_opening),
		str(enemy_targets_spread),
		str(speed_gear_ok),
		str(normal_animation_ok),
		str(fast_animation_ok),
		str(fast_auto_delay_ok),
		",".join(order),
	])
	host.get_tree().quit(0 if status == "ok" else 1)

