	var instance_text = host.pet_detail_label.text if host.pet_detail_label != null else ""
	var instance_button_y = host.pet_state_cycle_button.global_position.y if host.pet_state_cycle_button != null else -1.0
	var tabs_ready = (
		host.pet_detail_instance_button != null
		and host.pet_detail_codex_button != null
		and host.pet_detail_growth_button != null
		and host.pet_detail_instance_button.visible
		and host.pet_detail_codex_button.visible
		and host.pet_detail_growth_button.visible
		and host.pet_detail_instance_button.text == "个体"
		and host.pet_detail_codex_button.text == "图鉴"
		and host.pet_detail_growth_button.text == "成长"
		and host.pet_detail_instance_button.button_pressed
		and not host.pet_detail_codex_button.button_pressed
		and not host.pet_detail_growth_button.button_pressed
	)
	var instance_ok = (
		instance_text.find("黄色普通布伊") >= 0
		and instance_text.find("Lv1") >= 0
		and instance_text.find("生命：") >= 0
		and instance_text.find("经验：") >= 0
		and instance_text.find("图鉴：") < 0
	)

	host._set_pet_detail_mode(PET_DETAIL_MODE_CODEX)
	await host.get_tree().process_frame
	var codex_text = host.pet_detail_label.text if host.pet_detail_label != null else ""
	var codex_button_y = host.pet_state_cycle_button.global_position.y if host.pet_state_cycle_button != null else -2.0
	var codex_buttons_ok = (
		host.pet_detail_instance_button != null
		and host.pet_detail_codex_button != null
		and host.pet_detail_growth_button != null
		and not host.pet_detail_instance_button.button_pressed
		and host.pet_detail_codex_button.button_pressed
		and not host.pet_detail_growth_button.button_pressed
	)
	var codex_ok = (
		codex_text.find("图鉴：黄色普通布伊") >= 0
		and codex_text.find("种系：布伊系") >= 0
		and codex_text.find("亚种：普通布伊") >= 0
		and codex_text.find("形态：黄色普通布伊") >= 0
		and codex_text.find("属性：10风") >= 0
		and codex_text.find("成长倾向：敏捷") >= 0
		and codex_text.find("基础能力：生命 130") >= 0
		and codex_text.find("捕捉：可捕捉") >= 0
		and codex_text.find("可用技能：攻击、防御") >= 0
		and codex_text.find("被动技能: [抗性皮肤]") >= 0
	)
	var raw_hidden = codex_text.find("bui_normal_yellow_wind10") < 0 and codex_text.find("agility_high") < 0
	host._set_pet_detail_mode(PET_DETAIL_MODE_GROWTH)
	await host.get_tree().process_frame
	var growth_text = host.pet_detail_label.text if host.pet_detail_label != null else ""
	var growth_button_y = host.pet_state_cycle_button.global_position.y if host.pet_state_cycle_button != null else -3.0
	var growth_buttons_ok = (
		host.pet_detail_instance_button != null
		and host.pet_detail_codex_button != null
		and host.pet_detail_growth_button != null
		and not host.pet_detail_instance_button.button_pressed
		and not host.pet_detail_codex_button.button_pressed
		and host.pet_detail_growth_button.button_pressed
	)
	var growth_ok = (
		growth_text.find("暂无成长观察档") >= 0
		and host.pet_growth_radar != null
		and not host.pet_growth_radar.visible
	)
	var action_y_stable = absf(instance_button_y - codex_button_y) < 1.0 and absf(instance_button_y - growth_button_y) < 1.0

	host._set_pet_detail_mode(PET_DETAIL_MODE_INSTANCE)
	await host.get_tree().process_frame
	var returned_text = host.pet_detail_label.text if host.pet_detail_label != null else ""
	var returned_ok = (
		host.pet_detail_instance_button != null
		and host.pet_detail_codex_button != null
		and host.pet_detail_growth_button != null
		and host.pet_detail_instance_button.button_pressed
		and not host.pet_detail_codex_button.button_pressed
		and not host.pet_detail_growth_button.button_pressed
		and returned_text == instance_text
	)
	var growth_mix_label_ok = PlayerProgressModel.growth_profile_label("attack_agility") == "攻击 / 敏捷"
	var status = "ok" if tabs_ready and instance_ok and codex_buttons_ok and codex_ok and raw_hidden and growth_buttons_ok and growth_ok and action_y_stable and returned_ok and growth_mix_label_ok else "failed"
	print("pet codex detail check ready: status=%s tabs=%s instance=%s codex_buttons=%s codex=%s raw_hidden=%s growth_buttons=%s growth=%s action_y=%s returned=%s mixed_growth=%s" % [
		status,
		str(tabs_ready),
		str(instance_ok),
		str(codex_buttons_ok),
		str(codex_ok),
		str(raw_hidden),
		str(growth_buttons_ok),
