		str(forced_fast_enemy.get("formId", "")) == "wuli_normal_fast_wind10"
		and str(forced_fast_enemy.get("name", "")) == "高速乌力"
		and int(forced_fast_enemy.get("level", 0)) == 3
		and int(forced_fast_enemy.get("quick", 0)) == 88
