func _run_auto_hang_supply_closure_check() -> void:
	host.profile_save_enabled = false
	host.world_log_history.clear()
	host.world_log_message = ""
	host._clear_hang_heal_resume_route()
	var loaded = host._load_map("firebud_village_gate", "doctor_record")
	var zones = EncounterModel.encounter_zones(host.map_data)
	var zone_found = loaded and not zones.is_empty()
	var origin_cell = Vector2i(12, 16)
	if host.player != null:
		host.player.global_position = IsoMapModel.grid_to_world(host.map_data, Vector2i(9, 17))
		host.last_checked_player_cell = IsoMapModel.world_to_grid(host.map_data, host.player.global_position)

	host.player_profile = host._village_healer_check_profile(120)
	var settings = PlayerProgressModel.hang_settings(host.player_profile)
	settings[HangSettingsModel.LOW_HP_STOP_PERCENT_KEY] = 30
	settings[HangSettingsModel.LOW_HP_ACTION_KEY] = HangSettingsModel.LOW_HP_ACTION_TOWN_HEAL
	settings[HangSettingsModel.RESUME_AFTER_HEAL_KEY] = true
	host.player_profile = PlayerProgressModel.with_hang_settings(host.player_profile, settings)
	host.player_profile = PlayerProgressModel.start_hang_session(host.player_profile, "walk", "firebud_village_gate", origin_cell)
	var session = PlayerProgressModel.hang_session(host.player_profile)
	session = HangSettingsModel.session_with_pending_resume(session, true)
	host.player_profile = PlayerProgressModel.with_hang_session(host.player_profile, session)
	var before_coins = PlayerProgressModel.stone_coins(host.player_profile)
	var doctor = host._navigation_target_for_interaction_id("firebud_doctor")
	if not doctor.is_empty():
		host._open_interaction_dialog(doctor.get("interaction", {}) as Dictionary)
	await host.get_tree().process_frame
	host._auto_apply_hang_healer_if_open()
	await host.get_tree().process_frame
	if host.player != null:
		host.player.global_position = IsoMapModel.grid_to_world(host.map_data, origin_cell)
		host.player.clear_move_target()
		host.current_path_cells.clear()
	host._update_hang_heal_resume_route()
	await host.get_tree().process_frame
	var resumed_session = PlayerProgressModel.hang_session(host.player_profile)
	var healed_resume_ok = (
		zone_found
		and PlayerProgressModel.player_hp(host.player_profile) == PlayerProgressModel.player_max_hp(host.player_profile)
		and PlayerProgressModel.stone_coins(host.player_profile) < before_coins
		and not bool(resumed_session.get(HangSettingsModel.SESSION_PENDING_RESUME_KEY, false))
		and bool(resumed_session.get(HangSettingsModel.SESSION_ENABLED_KEY, false))
		and str(resumed_session.get(HangSettingsModel.SESSION_MODE_KEY, "")) == "walk"
		and host.hang_mode_active
		and host.world_log_message.find("继续挂机") >= 0
	)

	host._clear_hang_heal_resume_route()
	host._set_hang_mode(false)
	host.player_profile = host._village_healer_check_profile(0)
	host.player_profile = PlayerProgressModel.with_hang_settings(host.player_profile, settings)
	host.player_profile = PlayerProgressModel.start_hang_session(host.player_profile, "walk", "firebud_village_gate", origin_cell)
	session = PlayerProgressModel.hang_session(host.player_profile)
	session = HangSettingsModel.session_with_pending_resume(session, true)
	host.player_profile = PlayerProgressModel.with_hang_session(host.player_profile, session)
	if not doctor.is_empty():
		host._open_interaction_dialog(doctor.get("interaction", {}) as Dictionary)
	await host.get_tree().process_frame
	host._auto_apply_hang_healer_if_open()
	await host.get_tree().process_frame
	var poor_session = PlayerProgressModel.hang_session(host.player_profile)
	var poor_stop_ok = (
		not bool(poor_session.get(HangSettingsModel.SESSION_ENABLED_KEY, true))
		and not bool(poor_session.get(HangSettingsModel.SESSION_PENDING_RESUME_KEY, true))
		and not host.hang_heal_resume_active
		and host.world_log_message.find("挂机补给失败") >= 0
	)
	var status = "ok" if healed_resume_ok and poor_stop_ok else "failed"
	print("hang supply closure check ready: status=%s healed_resume=%s poor_stop=%s zone=%s" % [
		status,
		str(healed_resume_ok),
		str(poor_stop_ok),
		str(zone_found),
	])
	host.get_tree().quit(0 if status == "ok" else 1)

