	var parsed = ServerAuthClientModel.parse_auth_response(200, success_body)
	var parsed_session = parsed.get("session", {}) as Dictionary
	var summary = parsed_session.get("serverProfileSummary", {}) as Dictionary
	var parse_ok = (
