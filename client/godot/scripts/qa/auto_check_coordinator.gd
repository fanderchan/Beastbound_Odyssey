func _run_auto_player_stat_spam_perf_check() -> void:
	host.profile_save_enabled = true
	host.profile_save_dry_run = true
	host.profile_save_pending = false
	host.profile_save_debounce_remaining = 0.0
	host.profile_save_debug_count = 0
	host.player_status_refresh_debug_count = 0
	host.world_log_history.clear()
	host.world_log_message = ""
	var profile = PlayerProgressModel.default_profile()
	var player_dict = profile.get("player", {}) as Dictionary
	player_dict["level"] = 131
	player_dict["statPoints"] = 80
	profile["player"] = player_dict
	host.player_profile = PlayerProgressModel.normalize_profile(profile)
	host._load_map("firebud_village_gate", "from_training_yard")
	host._open_player_status_panel()
	await host.get_tree().process_frame
	var refresh_after_open = host.player_status_refresh_debug_count
	var start_usec = Time.get_ticks_usec()
	var keys: Array[String] = ["maxHp", "quick", "attack", "defense"]
	for index in range(60):
		host._on_player_status_allocate_pressed(keys[index % keys.size()])
	var elapsed_ms = float(Time.get_ticks_usec() - start_usec) / 1000.0
	var immediate_ok = host.profile_save_pending and host.profile_save_debug_count == 0
	var refresh_ok = host.player_status_refresh_debug_count <= refresh_after_open + 60
	await host.get_tree().create_timer(0.5).timeout
	var debounce_ok = (not host.profile_save_pending) and host.profile_save_debug_count == 1
	var points_ok = PlayerProgressModel.player_stat_points(host.player_profile) == 20
	var status = "ok" if immediate_ok and debounce_ok and refresh_ok and points_ok and elapsed_ms < 250.0 else "failed"
	print("player stat spam perf check ready: status=%s immediate=%s debounce=%s refresh=%s points=%s elapsed_ms=%.2f refresh_count=%d saves=%d" % [
		status,
		str(immediate_ok),
		str(debounce_ok),
		str(refresh_ok),
		str(points_ok),
		elapsed_ms,
		host.player_status_refresh_debug_count,
		host.profile_save_debug_count,
	])
	host.profile_save_dry_run = false
	host.profile_save_enabled = false
	host.get_tree().quit(0 if status == "ok" else 1)

