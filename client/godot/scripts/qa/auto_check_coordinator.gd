	var full_block_ok = (
		not bool(full_result.get("ok", false))
		and PlayerProgressModel.backpack_item_count(host.player_profile, BattleModel.ITEM_HEAL_SINGLE) == before_medicine
		and str(full_result.get("message", "")).find("生命已满") >= 0
	)

	host._select_backpack_slot(7)
	await host.get_tree().process_frame
	var capture_hidden_ok = host.backpack_use_button != null and not host.backpack_use_button.visible and host.backpack_detail_label.text.find("捕捉") >= 0
	host._close_backpack_panel()
	var status = "ok" if context_ok and detail_ok and use_button_ok and target_ok and world_use_ok and world_popup_ok and full_meat_target_enabled_ok and full_meat_ok and full_meat_popup_ok and full_block_ok and capture_hidden_ok else "failed"
	print("backpack world use check ready: status=%s context=%s detail=%s use_button=%s targets=%s world_use=%s world_popup=%s full_meat_target=%s full_meat=%s full_meat_popup=%s full_block=%s capture_hidden=%s hp=%d/%d meat=%d" % [
		status,
		str(context_ok),
		str(detail_ok),
		str(use_button_ok),
		str(target_ok),
		str(world_use_ok),
		str(world_popup_ok),
		str(full_meat_target_enabled_ok),
		str(full_meat_ok),
		str(full_meat_popup_ok),
		str(full_block_ok),
		str(capture_hidden_ok),
		int(after_pet.get("hp", 0)),
		max_hp,
		PlayerProgressModel.backpack_item_count(host.player_profile, BattleModel.ITEM_MEAT_SMALL),
	])
	host.get_tree().quit(0 if status == "ok" else 1)

func _run_auto_exp_pill_check() -> void:
	host.profile_save_enabled = false
	host.player_profile = PlayerProgressModel.default_profile()
	var grant_exp = PlayerProgressModel.exp_grant_for_level(131)
	var grant_exp_140 = PlayerProgressModel.exp_grant_for_level(140)
	var context_ok = (
		BackpackModel.item_can_world_player_exp(PlayerProgressModel.ITEM_EXP_PILL_LV1)
		and BackpackModel.item_can_world_pet_exp(PlayerProgressModel.ITEM_EXP_PILL_LV1)
		and BackpackModel.item_can_world_player_exp(PlayerProgressModel.ITEM_EXP_PILL_LV131)
		and BackpackModel.item_can_world_pet_exp(PlayerProgressModel.ITEM_EXP_PILL_LV131)
		and BackpackModel.item_can_world_player_exp(PlayerProgressModel.ITEM_EXP_PILL_LV140)
		and BackpackModel.item_can_world_pet_exp(PlayerProgressModel.ITEM_EXP_PILL_LV140)
		and EquipmentModel.slot_ids().has(EquipmentModel.SLOT_EXP_PILL)
		and EquipmentModel.slot_for(PlayerProgressModel.ITEM_EXP_PILL_LV1) == EquipmentModel.SLOT_EXP_PILL
		and EquipmentModel.slot_for(PlayerProgressModel.ITEM_EXP_PILL_LV131) == EquipmentModel.SLOT_EXP_PILL
		and EquipmentModel.slot_for(PlayerProgressModel.ITEM_EXP_PILL_LV140) == EquipmentModel.SLOT_EXP_PILL
		and grant_exp > 1000000
		and grant_exp_140 > grant_exp
	)
	var starter_ok = (
		PlayerProgressModel.backpack_item_count(host.player_profile, PlayerProgressModel.ITEM_EXP_PILL_LV131) >= 10
		and PlayerProgressModel.backpack_item_count(host.player_profile, PlayerProgressModel.ITEM_PLAYER_EXP_PILL_LV131) == 0
		and PlayerProgressModel.backpack_item_count(host.player_profile, PlayerProgressModel.ITEM_PET_EXP_PILL_LV131) == 0
	)

	host.player_profile = PlayerProgressModel.with_backpack_slots(host.player_profile, [
		{"itemId": PlayerProgressModel.ITEM_EXP_PILL_LV131, "count": 10},
		{"itemId": PlayerProgressModel.ITEM_EXP_PILL_LV140, "count": 2},
		{"itemId": PlayerProgressModel.ITEM_EXP_PILL_LV1, "count": 1},
	])
	var player_before_count = PlayerProgressModel.backpack_item_count(host.player_profile, PlayerProgressModel.ITEM_EXP_PILL_LV131)
	var player_use = PlayerProgressModel.use_world_player_exp_item(host.player_profile, PlayerProgressModel.ITEM_EXP_PILL_LV131)
	host.player_profile = player_use.get("profile", host.player_profile)
	var player_after = host.player_profile.get("player", {}) as Dictionary
	var player_use_ok = (
		bool(player_use.get("ok", false))
		and int(player_after.get("level", 1)) == 131
		and PlayerProgressModel.backpack_item_count(host.player_profile, PlayerProgressModel.ITEM_EXP_PILL_LV131) == player_before_count - 1
	)

	var pet_before_count = PlayerProgressModel.backpack_item_count(host.player_profile, PlayerProgressModel.ITEM_EXP_PILL_LV131)
	var pet_use = PlayerProgressModel.use_world_pet_exp_item(host.player_profile, PlayerProgressModel.ITEM_EXP_PILL_LV131, "pet_bui_main")
	host.player_profile = pet_use.get("profile", host.player_profile)
	var pet_after = PlayerProgressModel.pet_instance_by_id(host.player_profile, "pet_bui_main")
	var pet_use_ok = (
		bool(pet_use.get("ok", false))
		and int(pet_after.get("level", 1)) == 131
		and PlayerProgressModel.backpack_item_count(host.player_profile, PlayerProgressModel.ITEM_EXP_PILL_LV131) == pet_before_count - 1
	)

	var equip_result = PlayerProgressModel.equip_item(host.player_profile, PlayerProgressModel.ITEM_EXP_PILL_LV1)
	host.player_profile = equip_result.get("profile", host.player_profile)
	var charge = PlayerProgressModel.equipped_exp_pill_charge(host.player_profile)
	var equip_ok = (
		bool(equip_result.get("ok", false))
		and PlayerProgressModel.equipped_item_id(host.player_profile, EquipmentModel.SLOT_EXP_PILL) == PlayerProgressModel.ITEM_EXP_PILL_LV1
		and int(charge.get("level", 0)) == 1
	)

	var max_profile = PlayerProgressModel.normalize_profile(host.player_profile)
	var player_dict = (max_profile.get("player", {}) as Dictionary).duplicate(true)
	player_dict["level"] = PlayerProgressModel.MAX_PLAYER_LEVEL
	player_dict["exp"] = 0
	player_dict["nextExp"] = PlayerProgressModel.exp_to_next_level(PlayerProgressModel.MAX_PLAYER_LEVEL)
	max_profile["player"] = player_dict
	var charge_use = PlayerProgressModel.use_world_player_exp_item(max_profile, PlayerProgressModel.ITEM_EXP_PILL_LV140)
	var charge_profile = charge_use.get("profile", max_profile) as Dictionary
	var charged = PlayerProgressModel.equipped_exp_pill_charge(charge_profile)
	var charge_ok = (
		bool(charge_use.get("ok", false))
		and (int(charged.get("level", 0)) > 1 or int(charged.get("exp", 0)) > 0)
		and str(charge_use.get("message", "")).find("存入经验丹") >= 0
	)
	var locked_unequip = PlayerProgressModel.unequip_slot(charge_profile, EquipmentModel.SLOT_EXP_PILL)
	var lock_ok = (
		not bool(locked_unequip.get("ok", true))
		and str(locked_unequip.get("message", "")).find("储存经验") >= 0
	)

	var lv140_profile = PlayerProgressModel.with_backpack_slots(PlayerProgressModel.default_profile(), [
		{"itemId": PlayerProgressModel.ITEM_EXP_PILL_LV140, "count": 2},
	])
	var lv140_player_use = PlayerProgressModel.use_world_player_exp_item(lv140_profile, PlayerProgressModel.ITEM_EXP_PILL_LV140)
	lv140_profile = lv140_player_use.get("profile", lv140_profile)
	var lv140_pet_use = PlayerProgressModel.use_world_pet_exp_item(lv140_profile, PlayerProgressModel.ITEM_EXP_PILL_LV140, "pet_bui_main")
	lv140_profile = lv140_pet_use.get("profile", lv140_profile)
	var lv140_player = lv140_profile.get("player", {}) as Dictionary
	var lv140_pet = PlayerProgressModel.pet_instance_by_id(lv140_profile, "pet_bui_main")
	var lv140_use_ok = (
		bool(lv140_player_use.get("ok", false))
		and bool(lv140_pet_use.get("ok", false))
		and int(lv140_player.get("level", 1)) == PlayerProgressModel.MAX_PLAYER_LEVEL
		and int(lv140_pet.get("level", 1)) == PlayerProgressModel.MAX_PET_LEVEL
	)

	host.player_profile = PlayerProgressModel.default_profile()
	host.backpack_selected_slot_index = host._backpack_slot_index_for_item(PlayerProgressModel.ITEM_EXP_PILL_LV131)
	host._open_backpack_panel()
	await host.get_tree().process_frame
	var ui_ok = (
		host.backpack_use_button != null
		and host.backpack_use_button.visible
		and host.backpack_use_button.text == "使用"
		and host.backpack_equip_button != null
		and host.backpack_equip_button.visible
		and not host.backpack_equip_button.disabled
	)
	host._on_backpack_use_pressed()
	await host.get_tree().process_frame
	var target_ui_ok = (
		host.backpack_target_scroll != null
		and host.backpack_target_scroll.visible
		and host.backpack_target_container != null
		and host.backpack_target_container.get_child_count() >= 2
		and (host.backpack_target_container.get_child(0) as Button).text.find("见习猎人") >= 0
	)
	host._close_backpack_panel()

	var status = "ok" if context_ok and starter_ok and player_use_ok and pet_use_ok and equip_ok and charge_ok and lock_ok and lv140_use_ok and ui_ok and target_ui_ok else "failed"
	print("exp pill check ready: status=%s context=%s starter=%s player=%s pet=%s equip=%s charge=%s lock=%s lv140=%s ui=%s target_ui=%s grant=%d grant140=%d player_lv=%d pet_lv=%d" % [
		status,
		str(context_ok),
		str(starter_ok),
		str(player_use_ok),
		str(pet_use_ok),
		str(equip_ok),
		str(charge_ok),
		str(lock_ok),
		str(lv140_use_ok),
		str(ui_ok),
		str(target_ui_ok),
		grant_exp,
		grant_exp_140,
		int(player_after.get("level", 1)),
		int(pet_after.get("level", 1)),
	])
	host.get_tree().quit(0 if status == "ok" else 1)

func _run_auto_mailbox_check() -> void:
	host.profile_save_enabled = false
	var filler_ids = [
		"item_meat_small",
		"item_heal_all_5",
		"item_heal_single_5",
		"item_poison_single_5",
