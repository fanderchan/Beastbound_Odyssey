		str(low_block_ok),
		str(high_ok),
		str(bag_button_ok),
		str(bag_detail_ok),
		str(shop_detail_ok),
		str(rebirth_low_ok),
		str(rebirth_high_ok),
		str(rebirth_bag_ok),
		str(rebirth_shop_ok),
