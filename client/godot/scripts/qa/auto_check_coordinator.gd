func _run_auto_animation_state_check() -> void:
	var initial_idle: bool = host.player.get_animation_state() == "idle"
	var initial_clip: String = host.player.get_animation_clip_key()
	var target = IsoMapModel.grid_to_world(host.map_data, IsoMapModel.spawn_cell(host.map_data) + Vector2i(2, -2))
	host._set_click_move_target(host._world_to_screen(target))
	for _step in range(8):
		await host.get_tree().physics_frame
	var switched_to_walk: bool = host.player.get_animation_state() == "walk"
	var walk_clip: String = host.player.get_animation_clip_key()
	var guard = 0
	while host.player.is_auto_moving() and guard < 100:
		guard += 1
		await host.get_tree().physics_frame
	await host.get_tree().process_frame
	var returned_to_idle: bool = host.player.get_animation_state() == "idle"
	var final_clip: String = host.player.get_animation_clip_key()
	var clip_keys_ok = initial_clip == "idle_south" and walk_clip == "walk_east" and final_clip == "idle_east"
	var status = "ok" if initial_idle and switched_to_walk and returned_to_idle and clip_keys_ok else "failed"
	print("animation state check ready: status=%s initial_idle=%s switched_to_walk=%s returned_to_idle=%s initial_clip=%s walk_clip=%s final_clip=%s" % [
		status,
		str(initial_idle),
		str(switched_to_walk),
		str(returned_to_idle),
		initial_clip,
		walk_clip,
		final_clip,
	])
	host.get_tree().quit(0 if status == "ok" else 1)

func _run_auto_pet_follow_check() -> void:
	var hidden_by_default: bool = not host.pet_follow_enabled and not host.pet.visible
	host._set_pet_follow_enabled(true)
	var visible_after_ring: bool = host.pet_follow_enabled and host.pet.visible
	var start_pet_position: Vector2 = host.pet.global_position
