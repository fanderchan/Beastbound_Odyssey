	var high_storage_pet = PlayerProgressModel.create_pet_instance_from_form("pet_manage_high", "强乌力", "wuli_normal_fast_wind10", PlayerProgressModel.PET_STATE_STORAGE, 2, {
		"hp": 180,
		"maxHp": 180,
