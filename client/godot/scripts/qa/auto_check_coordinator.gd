	if not started:
		print("battle visual timing check ready: status=failed started=false")
		host.get_tree().quit(1)
		return
	var target_id = "enemy_front_3"
	host.battle_state = BattleModel.set_actor_hp(host.battle_state, target_id, 40)
	_set_host_battle_event_queue([{
		"type": "attack",
		"attackerId": "ally_attack_high",
		"targetId": target_id,
		"targetSide": BattleModel.SIDE_ENEMY,
		"damage": 16,
		"speed": 90,
			"sequence": 0,
			"movementStyle": "melee",
			"canLaunch": false,
			"canCounter": false,
			"forceDodge": false,
			"forceCritical": false,
		}])
	host.battle_state["phase"] = "round_events"
	host._play_next_battle_event()
	var actual_after_hit = BattleModel.actor_by_id(host.battle_state, target_id)
	var visual_before_hit = host._battle_actor_for_visual_draw(actual_after_hit)
	var reveal_progress = host._battle_event_result_reveal_progress(host.battle_current_event)
	host.battle_action_timer = host.battle_current_event_duration * maxf(0.0, 1.0 - reveal_progress - 0.03)
	var visual_after_hit = host._battle_actor_for_visual_draw(actual_after_hit)
	var delayed_hp_ok = int(actual_after_hit.get("hp", 0)) == 24 and int(visual_before_hit.get("hp", 0)) == 40 and int(visual_after_hit.get("hp", 0)) == 24

	started = host._start_stat_formula_test_battle()
	await host.get_tree().process_frame
	if not started:
		print("battle visual timing check ready: status=failed restarted=false")
		host.get_tree().quit(1)
		return
	host.battle_state = BattleModel.set_actor_hp(host.battle_state, target_id, 18)
	var combo_event = {
		"type": "combo_attack",
		"attackerId": "ally_speed_fast",
		"participantIds": ["ally_speed_fast", "ally_attack_high"],
		"targetId": target_id,
		"targetSide": BattleModel.SIDE_ENEMY,
		"damage": 96,
		"speed": 120,
		"sequence": 0,
		"movementStyle": "melee_combo",
		"canLaunch": true,
		"launchMode": "straight",
	}
	_set_host_battle_event_queue([combo_event])
	host.battle_state["phase"] = "round_events"
	host._play_next_battle_event()
	var combo_participant = BattleModel.actor_by_id(host.battle_state, "ally_speed_fast")
	var combo_home_start = host._battle_slot_world_position(str(combo_participant.get("slotId", "")))
	host.battle_action_timer = host.battle_current_event_duration * 0.50
	var combo_home_mid = host._battle_slot_world_position(str(combo_participant.get("slotId", "")))
	var combo_offset_mid = host._battle_actor_event_offset(combo_participant, combo_home_mid, host._battle_actor_visual_scale())
	host.battle_action_timer = host.battle_current_event_duration * 0.18
	var combo_home_late = host._battle_slot_world_position(str(combo_participant.get("slotId", "")))
	var slot_stable_ok = combo_home_start.distance_to(combo_home_mid) <= 0.01 and combo_home_start.distance_to(combo_home_late) <= 0.01 and combo_offset_mid.length() > 2.0
	var no_fixed_lunge_ok = (
		host._battle_actor_state_offset("attack", BattleModel.SIDE_ALLY, host._battle_actor_visual_scale()).length() <= 0.01
		and host._battle_actor_state_offset("combo", BattleModel.SIDE_ALLY, host._battle_actor_visual_scale()).length() <= 0.01
		and host._battle_actor_state_offset("skill", BattleModel.SIDE_ALLY, host._battle_actor_visual_scale()).length() <= 0.01
	)
	var combo_reveal = host._battle_event_result_reveal_progress(host.battle_current_event)
	var waits_at_old_launch_time = host._battle_launch_target_progress(BATTLE_LAUNCH_TARGET_START_RATIO + 0.03) <= 0.0
	var waits_before_combo_hit = host._battle_launch_target_progress(maxf(0.0, combo_reveal - 0.02)) <= 0.0
	var flies_after_combo_hit = host._battle_launch_target_progress(minf(0.98, combo_reveal + 0.08)) > 0.0
	var finishes_before_event_end = host._battle_launch_target_progress(0.96) >= 0.99
	var holds_until_event_end = host._battle_launch_target_progress(0.995) >= 0.99
	var combo_target_after = BattleModel.actor_by_id(host.battle_state, target_id)
	host.battle_action_timer = host.battle_current_event_duration * minf(1.0, 1.0 - combo_reveal + 0.02)
	var combo_visual_before_hit = host._battle_actor_for_visual_draw(combo_target_after)
	var combo_launch_timing_ok = combo_reveal > BATTLE_LAUNCH_TARGET_START_RATIO and waits_at_old_launch_time and waits_before_combo_hit and flies_after_combo_hit and finishes_before_event_end and holds_until_event_end and int(combo_visual_before_hit.get("hp", 0)) == 18
	host.battle_action_timer = 0.01
	host.battle_event_advance_pending = false
	host._update_battle_animation(0.02)
	var final_frame_hold_ok = host.battle_event_advance_pending and not host.battle_current_event.is_empty() and host._battle_current_event_progress() >= 0.99
	host._update_battle_animation(0.0)
	var advances_after_final_frame = not host.battle_event_advance_pending and host.battle_current_event.is_empty() and str(host.battle_state.get("phase", "")) == "command"
	host.battle_auto_attack_enabled = true
	host.battle_auto_attack_delay = 0.0
	host._finish_battle_round_and_open_commands()
