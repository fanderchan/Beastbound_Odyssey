		and bool(feed_result.get("ok", false))
		and int(fed_points.get("attack", 0)) == 5
		and int(feed_result.get("pointsAdded", 0)) == 5
		and PlayerProgressModel.backpack_item_count(host.player_profile, "mm_stone_attack_high") == before_stone_count - 1
	)

	var leveled_instances: Array = host.player_profile.get("petInstances", [])
	for index in range(leveled_instances.size()):
